{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "DQ: build current file",
      "type": "shell",
      "command": "dq-comp",
      "args": [
        "-g",
        "${file}",
        "-o",
        "${fileDirname}/${fileBasenameNoExtension}"
      ],
      "group": "build",
      "problemMatcher": "$dq"
    }
  ]
}

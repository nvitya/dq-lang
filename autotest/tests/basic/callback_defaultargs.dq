// callback default argument tests

type CBOne = function(a : int, b : int = 1) -> int;
type CBMany = function(a : int, b : int = 2, c : int = 3) -> int;
type CBSrc = function(a : int, b : int = 8) -> int;

function add(a : int, b : int = 9) -> int:
  result = a + b;
endfunc

function sum3(a : int, b : int, c : int) -> int:
  result = a + b + c;
endfunc

[[external]] function printf(fmt : ^cchar, ...) -> int;
function main() -> int:
  var cb : CBOne = add;
  var cb_src : CBSrc = add;
  var cb_dst : CBOne = cb_src;
  var cb_inline : function(a : int, b : int = 4) -> int = add;
  var cb_many : CBMany = sum3;

  printf("add(5) = %li\n", add(5));  //?check('add(5)', 14)
  printf("cb(5) = %li\n", cb(5));  //?check('cb(5)', 6)
  printf("cb_dst(5) = %li\n", cb_dst(5));  //?check('cb_dst(5)', 6)
  printf("cb_inline(5) = %li\n", cb_inline(5));  //?check('cb_inline(5)', 9)
  printf("cb_many(1) = %li\n", cb_many(1));  //?check('cb_many(1)', 6)
  printf("cb_many(1, 5) = %li\n", cb_many(1, 5));  //?check('cb_many(1, 5)', 9)
  printf("cb_many(1, 5, 7) = %li\n", cb_many(1, 5, 7));  //?check('cb_many(1, 5, 7)', 13)

  return 0;
endfunc

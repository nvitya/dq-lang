
use print;
use ./nanotime;

function StrToInt(sv : strview, defvalue : int64 = 0) -> int64:
  result = 0;
  var sign : int = 1;
  for i : int = 0 count sv.length:
    var c : char = sv[i];
    if c == '-':
      sign = -1;
    elif c >= '0'  and  c <= '9':
      result = result * 10 + int64(c - '0');
    else:
      return defvalue;
    endif
  endfor
endfunc

//-------------------------------------------------------

const default_maxval : int = 1000000;

var darr : [*]int32;

function FillArray(maxval : int32):
  darr.Clear();
  for i : int32 = 0 count maxval:
    darr.Append(i);
  endfor
endfunc

function FillArrayPtr(maxval : int32):
  darr.SetLength(maxval);
  var pi32 : ^int32 = &darr[0];
  for i : int32 = 0 count maxval:
    pi32[i]^ = i;
  endfor
endfunc


function CalcSum() -> int64:
  result = 0;
  var arrlen : int32 = darr.length;
  for i : int = 0 count arrlen:
    result += darr[i];  // range checked
  endfor
endfunc

function CalcSumPtr() -> int64:
  result = 0;
  var arrlen : int32 = darr.length;
  var pi32 : ^int32 = &darr[0];
  for i : int = 0 count arrlen:
    result += pi32[i]^;
  endfor
endfunc


function *Main() -> int:
  PrintLn('DynArray Test [DQ]');

  var maxval : int64 = default_maxval;

  if ParamCount() > 1:
    maxval = StrToInt(ParamStr(1), maxval);
  endif

  PrintLn('maxval = {}', [maxval]);

  var t1 : int64;
  var t2 : int64;
  var sum : int64 = 0;

  PrintLn('Filling the dynamic array...');
  t1 = NanoTime();
  FillArray(maxval);
  t2 = NanoTime();
  PrintLn('Total fill time: {} us', [(t2 - t1) IDIV 1000]);

  PrintLn('Summing the dynamic array...');
  t1 = NanoTime();
  sum = CalcSum();
  t2 = NanoTime();
  PrintLn('sum = {}', [sum]);
  PrintLn('Total sum time: {} us', [(t2 - t1) IDIV 1000]);

  PrintLn('\nUsing pointer operations\n');

  PrintLn('Filling the dynamic array (ptr)...');
  t1 = NanoTime();
  FillArrayPtr(maxval);
  t2 = NanoTime();
  PrintLn('Total fill time: {} us', [(t2 - t1) IDIV 1000]);

  PrintLn('Summing the dynamic array (ptr)...');
  t1 = NanoTime();
  sum = CalcSumPtr();
  t2 = NanoTime();
  PrintLn('sum = {}', [sum]);
  PrintLn('Total sum time: {} us', [(t2 - t1) IDIV 1000]);

  return 0;
endfunc
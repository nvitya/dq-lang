// C string test

// new type: "char": 8-bit char, same as "char" in C
// fixed cstring(N): N usable chars plus one hidden terminating zero byte

var dq_cstr  : cstring(255) = "DQ String Test\n";
var dq_cstr2 : cstring(39)  = 'Using signle quotes\n';

// These functions come from LIBC, so the program must be linked with the libc.
[[external]] function putchar(c : char) -> int;
[[external]] function puts(c : ^char) -> int;

function dq_writepc(s : ^char):
    var pc : ^char = s;
    while pc^ <> char(0):
        putchar(pc^);
        pc += 1;
    endwhile
endfunc

function dq_writestr(s : cstring):
    var pc : ^char = &s[0];
    while pc^ <> char(0):
        putchar(pc^);
        pc += 1;
    endwhile
endfunc

function cstr_add(dst : cstring, src : cstring):  // later this will be a DQ library function
    var ps     : ^char = &src[0];
    var psend  : ^char = ps + SizeOf(src);
    var pd     : ^char = &dst[0];
    var pdend  : ^char = pd + SizeOf(dst) - 1; // leave one char for the terminating
    pd += Len(dst);
    var pdstart : ^char = pd;

    while pd < pdend  and ps < psend  and ps^ <> char(0):
        pd^ = ps^;
        pd += 1;
        ps += 1;
    endwhile

    if pd <> pdstart:
        pd^ = char(0); // terminate
    endif
endfunc

function dq_str_append(a : cstring, b : cstring):

    // Len(cstring): length of the actual contents
    // SizeOf(cstring): storage size of the argument variable

    if Len(a) + Len(b) > SizeOf(a) - 1:  // append to the a only when the whole will fit.
        return;
    endif
    cstr_add(a, b);
endfunc
function *Main() -> int:
    dq_writepc('dq_cstr = ');
    dq_writestr(dq_cstr);  //?check('dq_cstr', 'DQ String Test')

    var s : cstring(127) = "";

    var warn_s1 : cstring(4); //?warning(CStrStorageSize)
    var warn_s2 : [[nowarn]] cstring(4);

    var hello : cstring(15) = "Hello";
    var world : cstring(15) = " World!\n";
    cstr_add(s, hello);
    cstr_add(s, world);

    dq_writepc('s = ');
    dq_writestr(s);
                             //?check('s', 'Hello World!')

    // string length checking test
    var s2 : [[nowarn]] cstring(8);
    s2 = "abc";
    var def : cstring(3) = "def";
    var too_long : cstring(15) = "ghijklmnopqr";
    dq_str_append(s2, def);
    dq_str_append(s2, too_long);

    dq_writepc('s2 = "');
    dq_writestr(s2);
    dq_writepc('"\n');     //?check(s2, '"abcdef"')

    var s3 : cstring(3) = "";
    var s4 : cstring(7) = "abcdef";
    s3 = s4;
    dq_writepc('s3 = "');
    dq_writestr(s3);
    dq_writepc('"\n');     //?check(s3, '"abc"')

    var s5 : cstring(7) = "";
    s5 = s3;
    dq_writepc('s5 = "');
    dq_writestr(s5);
    dq_writepc('"\n');     //?check(s5, '"abc"')

    var pc : ^char = "asdf";
    var cs : cstring(31);
    cs = pc;
    dq_writepc('cs = "');
    dq_writestr(cs);
    dq_writepc('"\n');     //?check(cs, '"asdf"')

    return 0;
endfunc

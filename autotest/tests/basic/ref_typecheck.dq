// reference type checking test (ERROR test)

function bad_default(a : ref int = 1):  //?error(FuncParDefaultRef)
endfunc

function old_param_mode_syntax(ref a : int):  //?error(FuncParNameInvalid)
endfunc

function takes_ref(a : ref int):
endfunc

function takes_refout(a : refout int):
    a = 1;
endfunc

function takes_refnull(a : refnull int):
    if &a == null:
        return;
    endif
endfunc

function bad_refin(a : refin int):
    a = 1;  //?error(RefReadonly)
endfunc

function bad_refout_read(a : refout int) -> int:
    result = a;  //?error(RefOutRead)
endfunc
function *Main() -> int:
    var x : int = 1;
    var y : int;

    takes_ref(1);  //?error(FuncArgRefBind)
    takes_ref(y);  //?error(FuncArgRefInit)
    takes_ref(null);  //?error(FuncArgRefNull)
    takes_refout(1);  //?error(FuncArgRefBind)
    takes_refnull(null);

    ref bad : int;  //?error(RefLocalInit)
    ref infer = 1;  //?error(RefLocalBind)
    ref mismatch : bool = x;  //?error(RefLocalType)
    refnull badnull : int;  //?error(RefLocalMode)
    return 0;
endfunc

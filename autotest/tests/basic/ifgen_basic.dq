//?notest

// Basic source fixture for module interface generation.
// Keep this free of use/usepath until imported module interfaces exist.

const IFGEN_BASE : int = 7;
const IFGEN_VALUES : int[3] = [1, 2, 3];

type TIfgenValue = int;

var g_var1 : int = 3;
var g_ptr : ^int;
var g_pptr : ^^int;

struct SIfgenPair
  tag    : byte;
  left   : int;
  right  : int;
  small  : uint16;
  values : int[3];
  ptr    : ^int;
endstruct

var g_struct : SIfgenPair;

object OIfgenBox
  tag   : byte;
  value : TIfgenValue;

  function Get() -> int:
    result = value;
  endfunc
endobj

[[external]] function printf(fmt : ^cchar, ...) -> int;

function IfgenAdd(a : int, b : int) -> int:
  result = a + b + IFGEN_BASE;
endfunc

function IfgenSliceLen(values : int[]) -> int:
  result = len(values);
endfunc

function testfunc() -> int:
  var pair : SIfgenPair = {};
  pair.left = 2;
  pair.right = 3;

  var box : OIfgenBox = {};
  box.value = IfgenAdd(pair.left, pair.right);

  printf("ifgen value = %d\n", box.Get());

  return 0;
endfunc

implementation

function IfgenPrivateHelper(v : int) -> int:
  result = v + 1;
endfunc

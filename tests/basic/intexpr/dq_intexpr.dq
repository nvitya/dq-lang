// single integer expression tests

//const GVINT    : int = 99;

var g_cnt : int = 0;
var g_var : int = 100; //GVINT + 1;

function dq_add(a : int, b : int) -> int:
  result = a + b;
endfunc

function dq_mul(a : int, b : int) -> int:
  result = a * b;
endfunc

function dq_voidfunc(a : int):
  g_cnt += a;
endfunc

function dq_call(a : int) -> int:
  var i : int;
  i = dq_add(3, a);
  //dq_voidfunc(1);
  result = i * a;
endfunc

function dq_testfunc(a : int, b : int) -> int: 
  var i : int = 0;
  result = 0;
  while i < b: 
    result += i;
    i += 1;
  endwhile
endfunc

function dq_testfunc2(a : int, b : int) -> int 
{
  var i : int = 0;
  result = 0;
  while i < b 
  {
    result += i;
    i += 1;
  }
}

function dq_ifcheck(a : int, b : int) -> int:
  if a < b:
    return -1;
  elif a > b:
    return 1;
  else:
    return 0;
  endif
endfunc

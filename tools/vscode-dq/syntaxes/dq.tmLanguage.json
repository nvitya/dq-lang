{
  "name": "DQ",
  "scopeName": "source.dq",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#directives"
    },
    {
      "include": "#attributes"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#function-declaration"
    },
    {
      "include": "#namespaces"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#builtins"
    },
    {
      "include": "#types"
    },
    {
      "include": "#function-call"
    },
    {
      "include": "#identifiers"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.dq",
          "begin": "/\\*",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.comment.begin.dq"
            }
          },
          "end": "\\*/",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.comment.end.dq"
            }
          }
        },
        {
          "name": "comment.line.double-slash.dq",
          "match": "//.*$"
        }
      ]
    },
    "directives": {
      "patterns": [
        {
          "name": "meta.preprocessor.dq",
          "begin": "^\\s*(#(?:if|ifdef|ifndef|elif|elifdef|elifndef|else|endif|define|include|include_once|linklib|opt|comp))\\b",
          "beginCaptures": {
            "1": {
              "name": "entity.name.function.preprocessor.dq"
            }
          },
          "end": "$",
          "patterns": [
            {
              "include": "#strings"
            },
            {
              "include": "#numbers"
            },
            {
              "include": "#keywords"
            },
            {
              "include": "#types"
            },
            {
              "include": "#operators"
            }
          ]
        },
        {
          "name": "meta.preprocessor.inline.dq",
          "begin": "(#\\{)\\s*(define|if|ifdef|ifndef|elif|elifdef|elifndef|else|endif|include|include_once|linklib|opt|comp)\\b",
          "beginCaptures": {
            "1": {
              "name": "punctuation.definition.preprocessor.dq"
            },
            "2": {
              "name": "entity.name.function.preprocessor.dq"
            }
          },
          "end": "\\}",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.preprocessor.dq"
            }
          },
          "patterns": [
            {
              "include": "#strings"
            },
            {
              "include": "#numbers"
            },
            {
              "include": "#keywords"
            },
            {
              "include": "#types"
            },
            {
              "include": "#operators"
            }
          ]
        }
      ]
    },
    "attributes": {
      "patterns": [
        {
          "name": "meta.annotation.dq",
          "begin": "\\[\\[",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.annotation.dq"
            }
          },
          "end": "\\]\\]",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.annotation.dq"
            }
          },
          "patterns": [
            {
              "include": "#strings"
            },
            {
              "name": "entity.name.function.dq",
              "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
            }
          ]
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.dq",
          "begin": "\"",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.dq"
            }
          },
          "end": "\"",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.dq"
            }
          },
          "patterns": [
            {
              "name": "constant.character.escape.dq",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.dq",
          "begin": "'",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.dq"
            }
          },
          "end": "'",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.dq"
            }
          },
          "patterns": [
            {
              "name": "constant.character.escape.dq",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.dq",
          "match": "(?<![A-Za-z0-9_])(?:\\d+\\.\\d+|\\d+\\.)(?:[eE][+-]?\\d+)?f?"
        },
        {
          "name": "constant.numeric.integer.dq",
          "match": "(?<![A-Za-z0-9_])\\d+(?![A-Za-z0-9_])"
        }
      ]
    },
    "function-declaration": {
      "patterns": [
        {
          "name": "meta.function.dq",
          "begin": "\\b(function)\\s+((?:[A-Za-z_][A-Za-z0-9_]*\\.)*)([A-Za-z_][A-Za-z0-9_]*)\\s*(\\()",
          "beginCaptures": {
            "1": {
              "name": "keyword.control.dq"
            },
            "2": {
              "name": "entity.name.type.dq"
            },
            "3": {
              "name": "entity.name.function.dq"
            },
            "4": {
              "name": "punctuation.section.parameters.begin.dq"
            }
          },
          "end": "(?=[:;])",
          "patterns": [
            {
              "name": "punctuation.section.parameters.end.dq",
              "match": "\\)"
            },
            {
              "name": "storage.type.dq",
              "match": "\\b(?:bool|int|uint|byte|int8|uint8|int16|uint16|int32|uint32|int64|uint64|char|cchar|cstring|float|float32|float64)\\b"
            },
            {
              "name": "keyword.control.dq",
              "match": "\\b(?:ref|refin|refout|refnull)\\b"
            },
            {
              "name": "variable.parameter.dq",
              "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\b(?=\\s*:)"
            },
            {
              "name": "keyword.operator.dq",
              "match": "->|\\^|:"
            }
          ]
        }
      ]
    },
    "function-call": {
      "patterns": [
        {
          "name": "entity.name.function.dq",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\b(?=\\s*\\()"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.dq",
          "match": "\\b(?:function|if|elif|else|endif|while|endwhile|for|endfor|return|break|continue|endfunc|result)\\b"
        },
        {
          "name": "keyword.control.dq",
          "match": "\\b(?:use|implementation|initialization|finalization|var|const|type|struct|endstruct|object|endobj|endobject|ref|refin|refout|refnull)\\b"
        },
        {
          "name": "keyword.operator.word.dq",
          "match": "\\b(?:and|or|not|AND|OR|XOR|NOT|IDIV|IMOD|SHL|SHR)\\b"
        },
        {
          "name": "constant.language.boolean.dq",
          "match": "\\b(?:true|false|null)\\b"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.builtin.dq",
          "match": "\\b(?:len|sizeof|round|ceil|floor)\\b(?=\\s*\\()"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.dq",
          "match": "\\b(?:bool|int|uint|byte|int8|uint8|int16|uint16|int32|uint32|int64|uint64|char|cchar|cstring|float|float32|float64)\\b"
        }
      ]
    },
    "namespaces": {
      "patterns": [
        {
          "name": "variable.language.namespace.dq",
          "match": "@(?:\\.?[A-Za-z_][A-Za-z0-9_]*(?:\\.[A-Za-z_][A-Za-z0-9_]*)*|\\.)?"
        },
        {
          "name": "entity.name.function.global.dq",
          "match": "(?<![A-Za-z0-9_])\\.[A-Za-z_][A-Za-z0-9_]*\\b(?=\\s*\\()"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.parameter.dq",
          "match": "(?<![@.#])\\b([A-Za-z_][A-Za-z0-9_]*)\\b(?!\\s*\\()"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.dq",
          "match": "\\[\\[|\\]\\]|->|<>|<=|>=|\\+=|-=|\\*=|/=|:=|\\^|[-+*/%=&<>@.:]"
        }
      ]
    }
  }
}

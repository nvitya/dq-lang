object OStrParse:
    bufstart : ^char
    bufend   : ^char
    readp    : ^char
    prevp    : ^char
    prevlen  : int

    commentmarker       : char = '#'
    float_decimal_point : char = '.'

    function *Create()                           [[overload]]
    function *Create(astr : ^char, alen : int)  [[overload]]
    function *Create(astr : strview)             [[overload]]

    function Init(astr : ^char, alen : int)

    function SkipSpaces(skiplineend : bool = true)
    function SkipWhite()

    function ReadLine() -> bool
    function ReadTo(checkchars : strview) -> bool
    function ReadToChar(achar : char) -> bool
    function ReadAlphaNum() -> bool
    function ReadDecimalNumbers() -> bool
    function ReadHexNumbers() -> bool
    function ReadFloatNum() -> bool
    function ReadQuotedString() -> bool
    function SearchPattern(checkstring : strview) -> bool

    function CheckSymbol(checkstring : strview) -> bool

    function PrevStr() -> str
    function UCComparePrev(checkstring : strview) -> bool
    function PrevToInt() -> int
    function PrevHexToInt() -> uint
    function PrevToFloat() -> float64

    function GetLineNum(pos : ^char) -> int  [[overload]]
    function GetLineNum() -> int              [[overload]]
    function GetColNum(pos : ^char) -> int   [[overload]]
    function GetColNum() -> int               [[overload]]

endobj

function PCharUCCompare(readp : ref ^char, len : int, checkstring : strview) -> bool
function PCharToInt(readp : ^char, len : int) -> int
function PCharHexToInt(readp : ^char, len : int) -> uint
function PCharToFloat(readp : ^char, len : int) -> float64

implementation

use math

function OStrParse.*Create()  [[overload]]:
    // no special init required
endfunc

function OStrParse.*Create(astr : strview)  [[overload]]:
    Init(^char(&astr[0]), astr.length)
endfunc

function OStrParse.*Create(astr : ^char, alen : int)  [[overload]]:
    Init(astr, alen)
endfunc

function OStrParse.Init(astr : ^char, alen : int):
    bufstart = astr
    bufend   = bufstart + alen

    readp = bufstart
    prevp = bufstart
    prevlen = 0
endfunc

function OStrParse.SkipSpaces(skiplineend : bool = true):
    var cp : ^char = readp
    while cp < bufend  and ( cp^ == ' '  or cp^ == '\t'  or (skiplineend and (cp^ == '\r'  or cp^ == '\n')) ):
        cp += 1
    endwhile
    readp = cp
endfunc

function OStrParse.SkipWhite():
    while true:
        SkipSpaces()
        if readp < bufend  and readp^ == commentmarker:
            ReadTo('\n\r')
        else:
            return
        endif
    endwhile
endfunc

function OStrParse.ReadLine() -> bool:
    prevp = readp
    var cp : ^char = readp

    while cp < bufend  and cp^ != '\r'  and cp^ != '\n':
        cp += 1
    endwhile

    prevlen = cp - readp

    // skip the line end, but only one CR and one LF
    if cp < bufend  and cp^ == '\r':
        cp += 1
    endif
    if cp < bufend  and cp^ == '\n':
        cp += 1
    endif

    readp = cp
    return prevp < bufend
endfunc

function OStrParse.ReadTo(checkchars : strview) -> bool:  // reads until one of the checkchars reached.
    var cp      : ^char = readp
    var ccstart : ^char = ^char(&checkchars[0])
    var ccend   : ^char = ccstart + checkchars.length
    var ccptr   : ^char

    prevp = readp

    while cp < bufend:
        // check chars
        ccptr = ccstart
        while ccptr < ccend:
            if ccptr^ == cp^:
                prevlen = cp - readp
                readp = cp
                return true
            endif
            ccptr += 1
        endwhile
        cp += 1
    endwhile

    // end of buffer, store the remaining length:
    prevlen = cp - readp
    readp   = cp
    return false
endfunc

function OStrParse.ReadToChar(achar : char) -> bool:
    result = false
    var cp : ^char = readp
    prevp = readp
    while cp < bufend:
        if cp^ == achar:
            result = true
            break
        endif
        cp += 1
    endwhile

    prevlen = cp - readp
    readp = cp
endfunc

function OStrParse.CheckSymbol(checkstring : strview) -> bool:
    var cp    : ^char = readp
    var csptr : ^char = ^char(&checkstring[0])
    var csend : ^char = csptr + checkstring.length

    while csptr < csend  and cp < bufend  and csptr^ == cp^:
        csptr += 1
        cp += 1
    endwhile

    if csptr != csend:
        return false
    endif

    readp = cp
    return true
endfunc

function OStrParse.ReadAlphaNum() -> bool:
    result = false
    var cp : ^char = readp
    prevp = readp

    while cp < bufend:
        var c : char = char(cp^)
        if ((c >= '0'  and c <= '9') or (c >= 'A'  and c <= 'Z') or (c >= 'a'  and c <= 'z')
            or c == '_' or (c == '-'  and cp == readp)):
            result = true
            cp += 1
        else:
            break
        endif
    endwhile

    prevlen = cp - readp
    readp = cp
endfunc

function OStrParse.ReadDecimalNumbers() -> bool:
    result = false
    var cp : ^char = readp
    prevp = readp

    while cp < bufend:
        var c : char = char(cp^)
        if c >= '0'  and c <= '9':
            result = true
            cp += 1
        else:
            break
        endif
    endwhile

    prevlen = cp - readp
    readp = cp
endfunc

function OStrParse.ReadHexNumbers() -> bool:
    result = false
    var cp : ^char = readp
    prevp = readp

    while cp < bufend:
        var c : char = char(cp^)
        if ((c >= '0'  and c <= '9') or (c >= 'A'  and c <= 'F') or (c >= 'a'  and c <= 'f')):
            result = true
            cp += 1
        else:
            break
        endif
    endwhile

    prevlen = cp - readp
    readp = cp
endfunc

function OStrParse.ReadFloatNum() -> bool:
    result = false
    var cp : ^char = readp
    prevp = readp

    while cp < bufend:
        var c : char = char(cp^)
        if ((c >= '0'  and c <= '9') or c == float_decimal_point
            or c == '-' or c == '+' or c == 'e' or c == 'E'):
            result = true
            cp += 1
        else:
            break
        endif
    endwhile

    prevlen = cp - readp
    readp = cp
endfunc

function OStrParse.ReadQuotedString() -> bool:
    if readp >= bufend:
        return false
    endif

    if readp^ != '"':
        return false
    endif

    readp += 1
    ReadToChar('"')

    if readp < bufend  and readp^ == '"':
        readp += 1
    endif

    return true
endfunc

function OStrParse.SearchPattern(checkstring : strview) -> bool:
    prevp = readp
    prevlen = 0

    var ccslen : int = checkstring.length
    if ccslen == 0:
        return true
    endif

    if ccslen > bufend - readp:
        return false
    endif

    var ccstart : ^char = ^char(&checkstring[0])
    var ccend   : ^char = ccstart + ccslen
    var cps     : ^char = readp
    var lastpos : ^char = bufend - ccslen

    while cps <= lastpos:
        var cp    : ^char = cps
        var ccptr : ^char = ccstart
        var match : bool = true

        while ccptr < ccend:
            if cp^ != ccptr^:
                match = false
                break
            endif
            cp += 1
            ccptr += 1
        endwhile

        if match:
            prevlen = cps - readp
            readp = cps
            return true
        endif

        cps += 1
    endwhile

    return false
endfunc

function OStrParse.PrevStr() -> str:
    result = ''
    var cp  : ^char = prevp
    var endp : ^char = prevp + prevlen

    while cp < endp:
        result.Append(char(cp^))
        cp += 1
    endwhile
endfunc

function OStrParse.UCComparePrev(checkstring : strview) -> bool:
    var cp : ^char = prevp
    return @.PCharUCCompare(cp, prevlen, checkstring)
endfunc

function OStrParse.PrevToInt() -> int:
    return @.PCharToInt(prevp, prevlen)
endfunc

function OStrParse.PrevHexToInt() -> uint:
    return @.PCharHexToInt(prevp, prevlen)
endfunc

function OStrParse.PrevToFloat() -> float64:
    return @.PCharToFloat(prevp, prevlen)
endfunc

function OStrParse.GetLineNum(pos : ^char) -> int  [[overload]]:
    result = 1
    var cp : ^char = bufstart

    while cp < pos  and cp < bufend:
        if cp^ == '\n':
            result += 1
        endif
        cp += 1
    endwhile
endfunc

function OStrParse.GetLineNum() -> int  [[overload]]:
    return GetLineNum(prevp)
endfunc

function OStrParse.GetColNum(pos : ^char) -> int  [[overload]]:
    if pos > bufend:
        pos = bufend
    endif

    var cp : ^char = pos
    while cp > bufstart:
        cp -= 1
        if cp^ == '\r'  or cp^ == '\n':
            return pos - cp
        endif
    endwhile

    return pos - bufstart + 1
endfunc

function OStrParse.GetColNum() -> int  [[overload]]:
    return GetColNum(prevp)
endfunc

function PCharUCCompare(readp : ref ^char, len : int, checkstring : strview) -> bool:
    var cp     : ^char = readp
    var endp   : ^char = cp + len
    var csptr  : ^char = ^char(&checkstring[0])
    var csend  : ^char = csptr + checkstring.length

    while csptr < csend  and cp < endp:
        var c : char = char(cp^)
        if c >= 'a'  and c <= 'z':
            c = char(Ord(c) - Ord('a') + Ord('A'))
        endif

        if c != csptr^:
            break
        endif

        csptr += 1
        cp += 1
    endwhile

    if csptr != csend:
        return false
    endif

    readp = cp
    return true
endfunc

function PCharToInt(readp : ^char, len : int) -> int:
    result = 0
    var cp   : ^char = readp
    var endp : ^char = readp + len

    while cp < endp:
        result = result * 10 + Ord(char(cp^)) - Ord('0')
        cp += 1
    endwhile
endfunc

function PCharHexToInt(readp : ^char, len : int) -> uint:
    result = 0
    var cp   : ^char = readp
    var endp : ^char = readp + len

    while cp < endp:
        var c : char = char(cp^)
        if c >= '0'  and c <= '9':
            result = (result << 4) + uint(Ord(c) - Ord('0'))
        elif c >= 'A'  and c <= 'F':
            result = (result << 4) + uint(Ord(c) - Ord('A') + 10)
        elif c >= 'a'  and c <= 'f':
            result = (result << 4) + uint(Ord(c) - Ord('a') + 10)
        else:
            break
        endif
        cp += 1
    endwhile
endfunc

function PCharToFloat(readp : ^char, len : int) -> float64:
    if len < 1:
        return 0.0
    endif

    var pc   : ^char = readp
    var pend : ^char = readp + len

    var nsign   : float64 = 1.0
    var esign   : float64 = 1.0
    var fracmul : float64 = 1.0
    var nv      : float64 = 0.0
    var ev      : float64 = 0.0
    var mode    : int = 0  // 0 = integer, 1 = fractional, 2 = exponent

    while pc < pend:
    var c : char = char(pc^)

    if c == '+':
        if mode == 2:
            esign = 1.0
        else:
            nsign = 1.0
        endif
    elif c == '-':
        if mode == 2:
            esign = -1.0
        else:
            nsign = -1.0
        endif
    elif c >= '0'  and c <= '9':
        var digit : float64 = float64(Ord(c) - Ord('0'))
        if mode == 1:
            fracmul *= 0.1
            nv += digit * fracmul
        elif mode == 2:
            ev = ev * 10.0 + digit
        else:
            nv = nv * 10.0 + digit
        endif
    elif c == '.'  or c == ',':
        mode = 1
    elif c == 'e'  or c == 'E':
        mode = 2
    else:
        break
    endif

    pc += 1
    endwhile

    return nsign * nv * Pow(10.0, esign * ev)
endfunc

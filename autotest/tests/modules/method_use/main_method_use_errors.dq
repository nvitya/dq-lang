use ./mod_method_use as onlym only(ONLY_A, imp_func)
use ./mod_method_use as exclm exclude(HIDDEN_A, hidden_func)

const OUTER_A : int = 5

object OMethodUseErrors:
public
    function BranchScope():
        if true:
            use .
        endif
        var v : int = OUTER_A
    endfunc  //?error(ObjVsInModuleNs)

    function DotDoesNotImport():
        use .
        var v : int = ONLY_A
    endfunc  //?error(ObjVsInModuleNs, 'Use "@exclm.ONLY_A"')

    function OnlyDoesNotIncludeHidden():
        use onlym
        var v : int = HIDDEN_A
    endfunc  //?error(VsUnknown)

    function LocalNamespaceDoesNotImport():
        var v : int = @..ONLY_A  //?error(NsVsUnknown)
    endfunc

    function UnknownAlias():
        use missing_alias  //?error(MethodUseInvalid)
    endfunc

    function StarWithAlias():
        use *, onlym  //?error(MethodUseInvalid)
    endfunc

    function StarWithDot():
        use *, .  //?error(MethodUseInvalid)
    endfunc

    function ModifierSyntax():
        use only  //?error(MethodUseInvalid)
    endfunc
endobj

function NormalFunctionUse():
    use .  //?error(MethodUseInvalid)
endfunc

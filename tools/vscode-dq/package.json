{
  "name": "dq-syntax",
  "displayName": "DQ Language Support",
  "description": "Minimal editor, build, and debug configuration support for DQ files.",
  "version": "0.0.1",
  "publisher": "local",
  "license": "UNLICENSED",
  "scripts": {
    "package": "vsce package --no-dependencies"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:nvitya/dq-comp.git"
  },
  "main": "./extension.js",
  "activationEvents": [
    "onCommand:dq.runCurrentFile"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "files": [
    "extension.js",
    "language-configuration.json",
    "package.json",
    "README.md",
    "LICENSE.txt",
    "examples/**",
    "snippets/**",
    "syntaxes/**"
  ],
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "dq",
    "syntax",
    "highlighting"
  ],
  "contributes": {
    "commands": [
      {
        "command": "dq.runCurrentFile",
        "title": "Run Current File",
        "category": "DQ",
        "enablement": "editorLangId == dq",
        "icon": "$(play)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "dq.runCurrentFile",
          "when": "editorLangId == dq",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "DQ",
      "properties": {
        "dq.runPath": {
          "type": "string",
          "default": "dq-run",
          "description": "Path to the dq-run executable used by DQ: Run Current File."
        }
      }
    },
    "languages": [
      {
        "id": "dq",
        "aliases": [
          "DQ",
          "dq"
        ],
        "extensions": [
          ".dq",
          ".dqh",
          ".dqi"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "dq",
        "scopeName": "source.dq",
        "path": "./syntaxes/dq.tmLanguage.json"
      }
    ],
    "problemMatchers": [
      {
        "name": "dq",
        "owner": "dq",
        "fileLocation": [
          "relative",
          "${workspaceFolder}"
        ],
        "pattern": {
          "regexp": "^(.*)\\((\\d+),(\\d+)\\)\\s+(error|warning|ERROR|WARNING)\\(([^)]+)\\):\\s+(.*)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "code": 5,
          "message": 6
        }
      }
    ],
    "breakpoints": [
      {
        "language": "dq"
      }
    ],
    "snippets": [
      {
        "language": "dq",
        "path": "./snippets/dq.json"
      }
    ]
  },
  "devDependencies": {
    "@vscode/vsce": "2.20.0"
  },
  "overrides": {
    "cheerio": "1.0.0-rc.12"
  }
}

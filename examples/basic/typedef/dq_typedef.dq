// type definition example

type TFloat = float64;

var f1 : TFloat = 1;
var f2 : TFloat = 2;
var f64 : float = 5.5;

[[external]] function printf(fmt : ^cchar, ...) -> int;

function main() -> int:
  printf('DQ Typedef test\n');
  var f : TFloat = f1;
  printf('float = %f\n', 0.1);
  printf('f64 = %f\n', f64);
  printf('f = %f\n', f);
  return 0;
endfunc
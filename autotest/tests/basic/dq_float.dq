// Float arithmetic and rounding tests

// --- constant expressions ---

const CONST_ROUND : int = round(3.1 / 1.13);   // round(2.7433...) = 3
const CONST_CEIL  : int = ceil(2.1 * 3.0);     // ceil(6.3) = 7
const CONST_FLOOR : int = floor(10.0 / 3.0);   // floor(3.333...) = 3

function dq_get_const_round() -> int:
  result = CONST_ROUND;
endfunc

function dq_get_const_ceil() -> int:
  result = CONST_CEIL;
endfunc

function dq_get_const_floor() -> int:
  result = CONST_FLOOR;
endfunc

// --- float64 arithmetic ---

function dq_fl_add(a : float64, b : float64) -> float64:
  result = a + b;
endfunc

function dq_fl_sub(a : float64, b : float64) -> float64:
  result = a - b;
endfunc

function dq_fl_mul(a : float64, b : float64) -> float64:
  result = a * b;
endfunc

function dq_fl_div(a : float64, b : float64) -> float64:
  result = a / b;
endfunc

// --- float32 arithmetic ---

function dq_fl32_add(a : float32, b : float32) -> float32:
  result = a + b;
endfunc

function dq_fl32_mul(a : float32, b : float32) -> float32:
  result = a * b;
endfunc

// --- round/ceil/floor on float64 ---

function dq_fl_round(v : float64) -> int:
  result = round(v);
endfunc

function dq_fl_ceil(v : float64) -> int:
  result = ceil(v);
endfunc

function dq_fl_floor(v : float64) -> int:
  result = floor(v);
endfunc

// --- round/ceil/floor on float32 ---

function dq_fl32_round(v : float32) -> int:
  result = round(v);
endfunc

function dq_fl32_ceil(v : float32) -> int:
  result = ceil(v);
endfunc

function dq_fl32_floor(v : float32) -> int:
  result = floor(v);
endfunc

[[external]] function printf(fmt : ^cchar, ...) -> int;

function main() -> int:
  printf("Testing DQ float operations:\n\n");     //?ignore('Testing DQ float operations:')

  printf("--- float64 arithmetic ---\n");         //?ignore('--- float64 arithmetic ---')
  printf('dq_fl_add(1.5, 2.5) = %.3f\n',     dq_fl_add(1.5, 2.5)  );  //?check('dq_fl_add(1.5, 2.5)', 4.000)
  printf("dq_fl_add(-1.5, 2.5) = %.3f\n",    dq_fl_add(-1.5, 2.5) );  //?check('dq_fl_add(-1.5, 2.5)', 1.000)
  printf("dq_fl_sub(5.5, 2.5) = %.3f\n",     dq_fl_sub(5.5, 2.5)  );  //?check('dq_fl_sub(5.5, 2.5)', 3.000)
  printf("dq_fl_sub(1.0, 3.5) = %.3f\n",     dq_fl_sub(1.0, 3.5)  );  //?check('dq_fl_sub(1.0, 3.5)',   -2.500)
  printf("dq_fl_mul(2.5, 4.0) = %.3f\n",     dq_fl_mul(2.5, 4.0)  );  //?check('dq_fl_mul(2.5, 4.0)',   10.000)
  printf("dq_fl_mul(-3.0, 2.5) = %.3f\n",    dq_fl_mul(-3.0, 2.5) );  //?check('dq_fl_mul(-3.0, 2.5)',  -7.500)
  printf("dq_fl_div(10.0, 4.0) = %.3f\n",    dq_fl_div(10.0, 4.0) );  //?check('dq_fl_div(10.0, 4.0)',   2.500)
  printf("dq_fl_div(-7.5, 2.5) = %.3f\n",    dq_fl_div(-7.5, 2.5) );  //?check('dq_fl_div(-7.5, 2.5)',  -3.000)

  // to be migrated:

#if false

  // ---- float32 arithmetic ----
  printf("\n--- float32 arithmetic ---\n");
  CHECK_F("dq_fl32_add(1.5f, 2.5f)",  dq_fl32_add(1.5f, 2.5f),  4.0f);
  CHECK_F("dq_fl32_mul(2.5f, 4.0f)",  dq_fl32_mul(2.5f, 4.0f), 10.0f);

  // ---- round (float64) ----
  printf("\n--- round(float64) -> int ---\n");
  CHECK_I("round(1.4)",    dq_fl_round(1.4),    1);
  CHECK_I("round(1.5)",    dq_fl_round(1.5),    2);   // ties away from zero
  CHECK_I("round(1.6)",    dq_fl_round(1.6),    2);
  CHECK_I("round(2.5)",    dq_fl_round(2.5),    3);   // ties away from zero
  CHECK_I("round(-1.4)",   dq_fl_round(-1.4),  -1);
  CHECK_I("round(-1.5)",   dq_fl_round(-1.5),  -2);   // ties away from zero
  CHECK_I("round(-1.6)",   dq_fl_round(-1.6),  -2);
  CHECK_I("round(0.0)",    dq_fl_round(0.0),    0);

  // ---- ceil (float64) ----
  printf("\n--- ceil(float64) -> int ---\n");
  CHECK_I("ceil(1.0)",     dq_fl_ceil(1.0),     1);
  CHECK_I("ceil(1.1)",     dq_fl_ceil(1.1),     2);
  CHECK_I("ceil(1.9)",     dq_fl_ceil(1.9),     2);
  CHECK_I("ceil(-1.1)",    dq_fl_ceil(-1.1),   -1);
  CHECK_I("ceil(-1.9)",    dq_fl_ceil(-1.9),   -1);
  CHECK_I("ceil(0.0)",     dq_fl_ceil(0.0),     0);

  // ---- floor (float64) ----
  printf("\n--- floor(float64) -> int ---\n");
  CHECK_I("floor(1.0)",    dq_fl_floor(1.0),    1);
  CHECK_I("floor(1.1)",    dq_fl_floor(1.1),    1);
  CHECK_I("floor(1.9)",    dq_fl_floor(1.9),    1);
  CHECK_I("floor(-1.1)",   dq_fl_floor(-1.1),  -2);
  CHECK_I("floor(-1.9)",   dq_fl_floor(-1.9),  -2);
  CHECK_I("floor(0.0)",    dq_fl_floor(0.0),    0);

  // ---- round/ceil/floor (float32) ----
  printf("\n--- round/ceil/floor(float32) -> int ---\n");
  CHECK_I("round32(1.5f)",   dq_fl32_round(1.5f),   2);
  CHECK_I("round32(-1.5f)",  dq_fl32_round(-1.5f), -2);
  CHECK_I("ceil32(1.1f)",    dq_fl32_ceil(1.1f),    2);
  CHECK_I("ceil32(-1.9f)",   dq_fl32_ceil(-1.9f),  -1);
  CHECK_I("floor32(1.9f)",   dq_fl32_floor(1.9f),   1);
  CHECK_I("floor32(-1.1f)",  dq_fl32_floor(-1.1f), -2);

  // ---- constant expressions ----
  printf("\n--- constant expressions (compile-time evaluation) ---\n");
  CHECK_I("CONST_ROUND = round(3.1/1.13)", dq_get_const_round(), 3);  // round(2.7433...) = 3
  CHECK_I("CONST_CEIL  = ceil(2.1*3.0)",   dq_get_const_ceil(),  7);  // ceil(6.3) = 7
  CHECK_I("CONST_FLOOR = floor(10.0/3.0)", dq_get_const_floor(), 3);  // floor(3.333...) = 3
#endif

  return 0;
endfunc
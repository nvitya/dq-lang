// define tests

//#define ERRORTEST

#define MAXVAL  = 1024 - 500
#define MAXMASK = MAXVAL - 1
#define BOOLVAL = false
#define SOMEDEF

var g_var : int = 555;

// #define STRVAL = "Defined String"  // string defines not supported yet

[[external]] function printf(fmt : ^cchar, ...) -> int;

function main() -> int:
  printf('Testing defines...\n');

  #ifdef BOOLVAL
    printf('BOOLVAL is defined.\n');
    #if BOOLVAL
      printf('  BOOLVAL is true\n');
    #else
      printf('  BOOLVAL is false\n');
    #endif
  #else
    printf('BOOLVAL is not defined.\n');
  #endif

  #ifdef BOOLVAL
    if @def.BOOLVAL:
      printf('  BOOLVAL (from normal source) is true\n');
    else:
      printf('  BOOLVAL (from normal source) is false\n');
    endif
  #endif

  #ifdef ERRORTEST
    #if NONEXISTING
      // non-existing define
    #endif

    #if MAXVAL
      // maxval is not boolean, compare operator required
    #endif
  #endif

  #if MAXVAL > 2000
    printf('MAXVAL > 2000\n');
  #elif MAXVAL >= 1000
    printf('MAXVAL >= 1000\n');
  #else
    printf('MAXVAL < 1000\n');
  #endif

  printf('MAXVAL = %ld\n', @def.MAXVAL);  // @ is used for namespace (scope) access.
                                          // The @def namespace points to the g_defines scope

  g_var = 123;
  @.g_var = 444;
  printf('g_var = %ld\n', @.g_var);

  @def.MAXVAL = 123;   // this should fail

  return 0;
endfunc
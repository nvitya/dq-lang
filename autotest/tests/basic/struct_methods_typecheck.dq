// struct method and managed member type checking

object OManaged:
endobj

struct SBadString:
    text : str; //?error(NotSupported)
endstruct //?error(ModStatementUnknown)

struct SBadDynArray:
    items : [*]int; //?error(NotSupported)
endstruct //?error(ModStatementUnknown)

struct SBadObject:
    item : OManaged; //?error(NotSupported)
endstruct //?error(ModStatementUnknown)

struct SBadFixedArray:
    items : [2]str; //?error(NotSupported)
endstruct //?error(ModStatementUnknown)

struct SNoLifecycle:
    function *Create(): //?error(ObjSpecFuncInvalid)
    endfunc
endstruct

struct SNoVirtual:
    function Bad() [[virtual]]: //?error(ObjFuncOverride)
    endfunc
endstruct

function *Main() -> int:
    return 0;
endfunc

// imported object inheritance test

use libc/stdio;
use ./inherit_mod;

function PrintImported(b : OModBase):
    @.printf("imported = %d\n", b.Get());
endfunc

function *Main() -> int:
    var c <- OModChild(11);
    PrintImported(c); //?check("imported", 23)
    c.PrintProt();    //?check('Protected_value', 11)
    return 0;
endfunc

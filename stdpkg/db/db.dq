  function RowsAffected() -> int64  [[virtual]]

  function LastError() -> str  [[virtual]]
  function LastErrorCode() -> int  [[virtual]]
endobj
*/

implementation

function ODbRows.CellIndex(arow : int, afield : int) -> int:
    if arow < 0  or  arow >= m_rowcount  or  afield < 0  or  afield >= m_fieldcount:
        return -1
    endif
    return arow * m_fieldcount + afield
endfunc

function ODbRows.*Create():
    m_fieldcount = 0
    m_rowcount = 0
    m_currow = -1
endfunc

function ODbRows.*Destroy():
    Clear()
endfunc

function ODbRows.Clear():
    ClearRows()
    m_fieldinfo.Clear(true)
    m_fieldcount = 0
endfunc

function ODbRows.ClearRows():
    m_data.Clear(true)
    m_rowcount = 0
    m_currow = -1
endfunc

function ODbRows.RowCount() -> int:
    return m_rowcount
endfunc

function ODbRows.FieldCount() -> int:
    return m_fieldcount
endfunc

function ODbRows.AddField(aname : str, atype : NSqlFieldType) -> int:
    if aname == '':
        return -1
    endif

    result = FieldIndex(aname)
    if result >= 0:
        return
    endif

    if m_fieldcount >= 256:
        return -1
    endif

    var old_fieldcount : int = m_fieldcount
    var new_fieldcount : int = old_fieldcount + 1

    if m_rowcount > 0:
        var newdata : [*]anyvalue = []
        newdata.SetLength(new_fieldcount * m_rowcount)
        for row : int = 0 count m_rowcount:
            for field : int = 0 count old_fieldcount:
                newdata[row * new_fieldcount + field] = m_data[row * old_fieldcount + field]
            endfor
        endfor
        m_data = newdata
    endif

    m_fieldinfo.SetLength(new_fieldcount)
    m_fieldinfo[old_fieldcount].name.Set(aname)
    m_fieldinfo[old_fieldcount].index = byte(old_fieldcount)
    m_fieldinfo[old_fieldcount].ftype = atype
    m_fieldinfo[old_fieldcount]._pad[0] = 0
    m_fieldinfo[old_fieldcount]._pad[1] = 0
    m_fieldcount = new_fieldcount
    return old_fieldcount
endfunc

function ODbRows.FieldName(aindex : int) -> str:
    if aindex < 0  or  aindex >= m_fieldcount:
        return ''
    endif
    return m_fieldinfo[aindex].name
endfunc

function ODbRows.FieldIndex(aname : str) -> int:
    for i : int = 0 count m_fieldcount:
        if m_fieldinfo[i].name == aname:
            return i
        endif
    endfor
    return -1
endfunc

function ODbRows.HasField(aname : str) -> bool:
    return FieldIndex(aname) >= 0
endfunc

function ODbRows.AddRow() -> int:
    result = m_rowcount
    m_rowcount += 1
    m_data.SetLength(m_fieldcount * m_rowcount)
    m_currow = result
endfunc

function ODbRows.DeleteRow(arow : int):
    if arow < 0  or  arow >= m_rowcount:
        return
    endif

    if m_fieldcount > 0:
        m_data.Delete(arow * m_fieldcount, m_fieldcount)
    endif
    m_rowcount -= 1

    if m_rowcount <= 0:
        m_currow = -1
    elif m_currow > arow:
        m_currow -= 1
    elif m_currow >= m_rowcount:
        m_currow = m_rowcount - 1
    endif
endfunc

function ODbRows.First():
    if m_rowcount > 0:
        m_currow = 0
    else:
        m_currow = -1
    endif
endfunc

function ODbRows.Last():
    if m_rowcount > 0:
        m_currow = m_rowcount - 1
    else:
        m_currow = -1
    endif
endfunc

function ODbRows.Next():
    if m_rowcount <= 0:
        m_currow = -1
    elif m_currow < m_rowcount:
        m_currow += 1
    else:
        m_currow = m_rowcount
    endif
endfunc

function ODbRows.Prev():
    if m_rowcount <= 0:
        m_currow = -1
    elif m_currow >= m_rowcount:
        m_currow = m_rowcount - 1
    else:
        m_currow -= 1
    endif
endfunc

function ODbRows.SelectRow(arow : int) -> bool:
    if arow >= 0  and  arow < m_rowcount:
        m_currow = arow
        return true
    endif
    return false
endfunc

function ODbRows.RowIndex() -> int:
    return m_currow
endfunc

function ODbRows.Eof() -> bool:
    return m_rowcount <= 0  or  m_currow >= m_rowcount
endfunc

function ODbRows.Bof() -> bool:
    return m_rowcount <= 0  or  m_currow < 0
endfunc

function ODbRows.IsNull(aname : str) -> bool:
    var idx : int = CellIndex(m_currow, FieldIndex(aname))
    if idx < 0:
        return true
    endif
    return m_data[idx].IsNull()
endfunc

function ODbRows.GetValue(aname : str) -> anyvalue:
    var nv : anyvalue
    nv.SetNull()
    result = nv
    var idx : int = CellIndex(m_currow, FieldIndex(aname))
    if idx >= 0:
        result = m_data[idx]
    endif
endfunc

function ODbRows.SetValue(aname : str, avalue : anyvalue):
    var idx : int = CellIndex(m_currow, FieldIndex(aname))
    if idx >= 0:
        m_data[idx] = avalue
    endif
endfunc

function ODbRows.GetInt(aname : str, defvalue : int) -> int:
    var idx : int = CellIndex(m_currow, FieldIndex(aname))
    if idx < 0:
        return defvalue
    endif
    return m_data[idx].AsInt(defvalue)
endfunc

function ODbRows.GetFloat(aname : str, defvalue : float) -> float:
    var idx : int = CellIndex(m_currow, FieldIndex(aname))
    if idx < 0:
        return defvalue
    endif
    return m_data[idx].AsFloat(defvalue)
endfunc

function ODbRows.GetBool(aname : str, defvalue : bool) -> bool:
    var idx : int = CellIndex(m_currow, FieldIndex(aname))
    if idx < 0:
        return defvalue
    endif
    return m_data[idx].AsBool(defvalue)
endfunc

function ODbRows.GetStr(aname : str, defvalue : str) -> str:
    var idx : int = CellIndex(m_currow, FieldIndex(aname))
    if idx < 0:
        return defvalue
    endif
    return m_data[idx].AsStr(defvalue)
endfunc

function ODbRows.SetInt(aname : str, avalue : int):
    SetValue(aname, avalue)
endfunc

function ODbRows.SetFloat(aname : str, avalue : float):
    SetValue(aname, avalue)
endfunc

function ODbRows.SetBool(aname : str, avalue : bool):
    SetValue(aname, avalue)
endfunc

function ODbRows.SetStr(aname : str, avalue : str):
    SetValue(aname, avalue)
endfunc

function ODbRows.SetNull(aname : str):
    var idx : int = CellIndex(m_currow, FieldIndex(aname))
    if idx >= 0:
        m_data[idx].SetNull()
    endif
endfunc

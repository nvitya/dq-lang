{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "cmake-configure-dqatrun",
      "type": "shell",
      "command": "cmake",
      "args": [
        "-S",
        "${workspaceFolder}/atrunner",
        "-B",
        "${workspaceFolder}/atrunner/build"
      ],
      "problemMatcher": []
    },
    {
      "label": "build-dqatrun",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        ".",
        "-j"
      ],
      "options": {
        "cwd": "${workspaceFolder}/atrunner/build"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "dependsOn": "cmake-configure-dqatrun",
      "problemMatcher": [
        "$gcc"
      ]
    }
  ]
}

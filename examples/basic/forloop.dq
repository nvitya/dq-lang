use libc/stdio;

function *Main() -> int:
  printf('For loop test\n');

  for i : int = 0 to 5:
    printf(' %d', i);
  endfor
  printf('\n');

  for i : int = 0 count 5 step 2:
    printf(' %d', i);
  endfor
  printf('\n');

  for i : int = 0 while i < 3:
    printf(' %d', i);
  endfor
  printf('\n');


  return 0;
endfunc
// object function reference tests

use libc/stdio;

type FObjText = function(msg : cstring) of object;
type FObjInt = function(v : int) of object;
type FPlainText = function(msg : cstring);

function plain(msg : cstring):
  printf("plain = %s\n", &msg[0]);
endfunc

object OCallback:
  name : cstring(32);

  function *Create(aname : cstring):
    name = aname;
  endfunc

  function Print(msg : cstring):
    @.printf("%s = %s\n", &name, &msg[0]);
  endfunc

  function Pick(msg : cstring) [[overload]]:
    @.printf("%s.picked = %s\n", &name, &msg[0]);
  endfunc

  function Pick(v : int) [[overload]]:
    @.printf("%s.picked = %d\n", &name, v);
  endfunc
endobj

function *Main() -> int:
  var first_name : cstring(5) = "first";
  var second_name : cstring(6) = "second";
  var first <- OCallback(first_name);
  var second <- OCallback(second_name);
  var cb : FObjText = null;
  var icb : FObjInt = null;
  var plaincb : FPlainText = plain;
  var msg_a : cstring(1) = "a";
  var msg_b : cstring(1) = "b";
  var msg_c : cstring(1) = "c";
  var msg_ok : cstring(2) = "ok";

  if cb == null:
    printf("cb = null\n");  //?check('cb', 'null')
  endif

  cb = first.Print;
  if cb != null:
    cb(msg_a);  //?check('first', 'a')
  endif

  cb = second.Print;
  cb(msg_b);  //?check('second', 'b')

  cb = first.Pick;
  cb(msg_c);  //?check('first.picked', 'c')

  icb = second.Pick;
  icb(5);  //?check('second.picked', 5)

  plaincb(msg_ok);  //?check('plain', 'ok')
  return 0;
endfunc

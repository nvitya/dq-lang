// struct/object layout, alignment, and packing

struct SLayoutNormal:
  a : byte;
  b : uint32;
  c : uint16;
endstruct

struct SLayoutFieldAlign:
  a : byte;
  b : uint16 [[align(8)]];
endstruct

[[packed]] struct SLayoutPacked:
  a : byte;
  b : uint32;
  c : uint16;
endstruct

[[packed]] struct SLayoutPackedAlignIgnored:
  a : byte;
  b : uint16 [[align(8)]];
endstruct

struct SLayoutNested:
  a : byte;
  p : SLayoutPacked;
  b : uint32;
endstruct

[[packed]] object OLayoutPackedObj:
  a : byte;
  b : uint32;
endobj

[[external]] function printf(fmt : ^cchar, ...) -> int;

function off_normal_b() -> int:
  var s : SLayoutNormal = {};
  result = int(uint(&s.b) - uint(&s.a));
endfunc

function off_normal_c() -> int:
  var s : SLayoutNormal = {};
  result = int(uint(&s.c) - uint(&s.a));
endfunc

function off_field_align_b() -> int:
  var s : SLayoutFieldAlign = {};
  result = int(uint(&s.b) - uint(&s.a));
endfunc

function off_packed_b() -> int:
  var s : SLayoutPacked = {};
  result = int(uint(&s.b) - uint(&s.a));
endfunc

function off_packed_c() -> int:
  var s : SLayoutPacked = {};
  result = int(uint(&s.c) - uint(&s.a));
endfunc

function off_packed_align_ignored_b() -> int:
  var s : SLayoutPackedAlignIgnored = {};
  result = int(uint(&s.b) - uint(&s.a));
endfunc

function off_nested_p() -> int:
  var s : SLayoutNested = {};
  result = int(uint(&s.p) - uint(&s.a));
endfunc

function off_nested_b() -> int:
  var s : SLayoutNested = {};
  result = int(uint(&s.b) - uint(&s.a));
endfunc

function packed_array_stride() -> int:
  var a : [2]SLayoutPacked;
  a[0].a = 0;
  a[1].a = 0;
  result = int(uint(&a[1]) - uint(&a[0]));
endfunc

function off_packed_obj_b() -> int:
  var o <- OLayoutPackedObj;
  result = int(uint(&o.b) - uint(&o.a));
endfunc
function *Main() -> int:
  printf("Testing struct layout:\n");  //?ignore('Testing struct layout:')

  printf("SizeOf(SLayoutNormal) = %li\n", SizeOf(SLayoutNormal));  //?check('SizeOf(SLayoutNormal)', 12)
  printf("OffsetOf(SLayoutNormal, a) = %li\n", OffsetOf(SLayoutNormal, a));  //?check('OffsetOf(SLayoutNormal, a)', 0)
  printf("OffsetOf(SLayoutNormal, b) = %li\n", OffsetOf(SLayoutNormal, b));  //?check('OffsetOf(SLayoutNormal, b)', 4)
  printf("OffsetOf(SLayoutNormal, c) = %li\n", OffsetOf(SLayoutNormal, c));  //?check('OffsetOf(SLayoutNormal, c)', 8)
  printf("off_normal_b() = %li\n", off_normal_b());                //?check('off_normal_b()', 4)
  printf("off_normal_c() = %li\n", off_normal_c());                //?check('off_normal_c()', 8)

  printf("SizeOf(SLayoutFieldAlign) = %li\n", SizeOf(SLayoutFieldAlign));  //?check('SizeOf(SLayoutFieldAlign)', 16)
  printf("OffsetOf(SLayoutFieldAlign, b) = %li\n", OffsetOf(SLayoutFieldAlign, b));  //?check('OffsetOf(SLayoutFieldAlign, b)', 8)
  printf("off_field_align_b() = %li\n", off_field_align_b());              //?check('off_field_align_b()', 8)

  printf("SizeOf(SLayoutPacked) = %li\n", SizeOf(SLayoutPacked));  //?check('SizeOf(SLayoutPacked)', 7)
  printf("OffsetOf(SLayoutPacked, b) = %li\n", OffsetOf(SLayoutPacked, b));  //?check('OffsetOf(SLayoutPacked, b)', 1)
  printf("OffsetOf(SLayoutPacked, c) = %li\n", OffsetOf(SLayoutPacked, c));  //?check('OffsetOf(SLayoutPacked, c)', 5)
  printf("off_packed_b() = %li\n", off_packed_b());                //?check('off_packed_b()', 1)
  printf("off_packed_c() = %li\n", off_packed_c());                //?check('off_packed_c()', 5)

  printf("SizeOf(SLayoutPackedAlignIgnored) = %li\n", SizeOf(SLayoutPackedAlignIgnored));  //?check('SizeOf(SLayoutPackedAlignIgnored)', 3)
  printf("OffsetOf(SLayoutPackedAlignIgnored, b) = %li\n", OffsetOf(SLayoutPackedAlignIgnored, b));  //?check('OffsetOf(SLayoutPackedAlignIgnored, b)', 1)
  printf("off_packed_align_ignored_b() = %li\n", off_packed_align_ignored_b());            //?check('off_packed_align_ignored_b()', 1)

  printf("SizeOf(SLayoutNested) = %li\n", SizeOf(SLayoutNested));  //?check('SizeOf(SLayoutNested)', 12)
  printf("OffsetOf(SLayoutNested, p) = %li\n", OffsetOf(SLayoutNested, p));  //?check('OffsetOf(SLayoutNested, p)', 1)
  printf("OffsetOf(SLayoutNested, b) = %li\n", OffsetOf(SLayoutNested, b));  //?check('OffsetOf(SLayoutNested, b)', 8)
  printf("off_nested_p() = %li\n", off_nested_p());                //?check('off_nested_p()', 1)
  printf("off_nested_b() = %li\n", off_nested_b());                //?check('off_nested_b()', 8)
  printf("packed_array_stride() = %li\n", packed_array_stride());  //?check('packed_array_stride()', 7)

  printf("SizeOf(OLayoutPackedObj) = %li\n", SizeOf(OLayoutPackedObj));  //?check('SizeOf(OLayoutPackedObj)', 5)
  printf("OffsetOf(OLayoutPackedObj, b) = %li\n", OffsetOf(OLayoutPackedObj, b));  //?check('OffsetOf(OLayoutPackedObj, b)', 1)
  printf("off_packed_obj_b() = %li\n", off_packed_obj_b());              //?check('off_packed_obj_b()', 1)

  return 0;
endfunc

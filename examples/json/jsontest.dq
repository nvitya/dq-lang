// testing the DQ JSON library

use print
use json
use strutils

function *Main() -> int:
  PrintLn('DQ JSON test')

  var jroot = new OJson()
  var jns : OJson
  var jnn : OJson
  var jno : OJson
  var jn : OJson

  jns = jroot.AddStr('strnode', 'hello')
  jnn = jroot.AddNum('numnode', 3.14)
  jno = jroot.AddObj('objnode')

  jn = jno.AddStr('substr', 'abc')
  jn = jno.AddNum('subnum', 42)

  jn.as_num = 46

  jn = jroot.AddArr('arrnode')
  jn.AddNum('', 1)
  jn.AddNum('', 2)
  jn.AddNum('', 3)

  PrintLn('"{}" = "{}"', [jns.name, jns.as_str])
  PrintLn('"{}" = "{}"', [jnn.name, jnn.as_num])

  PrintLn('"{}" = "{}"', [jn.name, jn.as_num])

  PrintLn('as json:')
  PrintLn(jroot.GetAsJson())

  return 0
endfunc
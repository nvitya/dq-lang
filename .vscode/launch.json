{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "DQ: Debug configured target",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/${config:dq.debugTarget}",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/${config:dq.debugCwd}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "${workspaceFolder}/.vscode/gdb_wrapper.sh",
            "preLaunchTask": "dq: build configured target"
        },
        {
            "name": "DQ: Debug active file",
            "type": "cppdbg",
            "request": "launch",
            "program": "${fileDirname}/${fileBasenameNoExtension}",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${fileDirname}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "${workspaceFolder}/.vscode/gdb_wrapper.sh",
            "preLaunchTask": "dq: build active file"
        },
        {
            "name": "CMake Debug",
            "type": "cppdbg",
            "request": "launch",
            "program": "${command:cmake.launchTargetPath}",

            "xargs": ["autotest/tests/basic/typecheck.dq", "-g", "-v"],
            "args": ["autotest/tests/basic/iif.dq", "-g", "-v"],

            "stopAtEntry": false,

            "cwd": "${workspaceFolder}",
            "environment": [
                {
                    "name": "PATH",
                    "value": "${env:PATH}:${command:cmake.getLaunchTargetDirectory}"
                }
            ],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Disable debuginfod",
                    "text": "set debuginfod enabled off",
                    "ignoreFailures": true
                },
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "DQ: Debug bare test1 with J-Link",
            "type": "cortex-debug",
            "request": "launch",

            "servertype": "external",
            "gdbTarget": "localhost:2331",

            "device": "Cortex-M7",
            "interface": "swd",

            "cwd": "${workspaceFolder}/examples/bare/test1",
            "executable": "${workspaceFolder}/examples/bare/test1/test1.elf",

            "gdbPath": "/usr/bin/gdb-multiarch",
            "objdumpPath": "/usr/bin/llvm-objdump",

            "preLaunchTask": "dq: build bare test1",

            "overrideLaunchCommands": [
                "monitor reset",
                "-target-download",
                "set $pc = soft_entry"
            ],

            "overrideResetCommands": [
                "monitor reset",
                "set $pc = soft_entry"
            ],

            "runToEntryPoint": "_start",
            "showDevDebugOutput": "raw"
        }
    ]
}

// test for not initialized variables

struct SVarInit:
    value : int;
endstruct

var g_cnt : int;  // globals are initialized with zero, when not specified
var g_var : int = 100;

function dq_noresult(a : int) -> int:
    // error missing result / return
endfunc  //?error(FuncResultNotSet)

function dq_localvar_noinit(a : int) -> int:
    var i : int;
    result = a * i;  //?error(VarNotInit)
endfunc


function dq_localvar_initok(a : int) -> int:
    var i : int;
    if a < 2:
        i = 1;
    elif a < 5:
        i = 2;
    elif a < 10:
        i = 3;
    else:
        i = 4;
    endif
    result = a * i;
endfunc

function dq_localvar_noinit_if(a : int) -> int:
    var i : int;
    if a < 2:
        i = 1;
    elif a < 5:
        i = 2;
    elif a < 10:
        i = 3;
    endif
    result = a * i;  //?error(VarNotInit)
endfunc

function dq_result(a : int) -> int:
    if   a < 2:
        result = 1;
    elif a < 5:
        result = 2;
    elif a < 10:
        result = 3;
    else:
        result = 4;
    endif
endfunc

function dq_localvar_modassign_noinit() -> int:
    var i : int;
    i += 1;  //?error(VarNotInit)
    result = 0;
endfunc

function dq_ptrassign_noinit() -> int:
    var p : ^byte;
    p^ = 1;  //?error(VarNotInit)
    result = 0;
endfunc

function dq_ptrmember_noinit() -> int:
    var p : ^SVarInit;
    p^.value = 1;  //?error(VarNotInit)
    result = 0;
endfunc

function dq_array_elem_modassign_noinit() -> int:
    var a : [2]int;
    a[0] += 1;
    result = 0;
endfunc

function dq_array_elem_plainassign_ok() -> int:
    var a : [2]int;
    a[0] = 1;
    result = a[0];
endfunc

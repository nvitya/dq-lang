// ODynArrMgr regression tests

use libc/stdio;
use rtl/dynarrmgr;

function PrintMgr(label : ^char, arr : ref ODynArrMgr):
    var arrlen : uint = DynArrGetLength(arr);
    printf("%s = len:%li, cap:%li, data: [", label, arrlen, DynArrGetCapacity(arr));

    var i : int = 0;
    while i < arrlen:
        if i > 0:  printf(",");  endif
        printf("%li", ^int(DynArrGetElemPtr(arr, i))^);
        i += 1;
    endwhile

    printf("]\n");
endfunc

function PrintRefState(label : ^char, arr : ODynArrMgr):
    if arr == null:
        printf("%s = null\n", label);
    else:
        printf("%s = refcount:%li, len:%li, cap:%li\n", label, arr.refcount, arr.length, arr.capacity);
    endif
endfunc

function PrintSlice(label : ^char, desc : SArraySliceDesc):
    printf("%s = len:%li, data: [", label, desc.length);
    var i : int = 0;
    while i < desc.length:
        if i > 0:  printf(",");  endif
        printf(" %li", ^int(^byte(desc.dataptr)[i * SizeOf(int)])^);
        i += 1;
    endwhile
    printf("]\n");
endfunc

function MakeIntTypeInfo(ti : refout SDqTypeInfo):
    ti.storagesize = SizeOf(int);
    ti.flags = 0;
    ti.kind = DQTK_INT;
    ti.subtype = 0;
    ti.init_func = null;
    ti.destroy_func = null;
    ti.copy_func = null;
    ti.move_func = null;
endfunc

function RunCoreOps(ti : ^SDqTypeInfo):
    var arr : ODynArrMgr = null;
    PrintMgr("initial", arr);

    var first : [5]int = [10, 20, 30, 40, 50];
    DynArrAppend(arr, ti, &first[0], 5);
    PrintMgr("append5", arr);

    var ins : [2]int = [111, 222];
    DynArrInsert(arr, ti, 1, &ins[0], 2);
    PrintMgr("insert-mid", arr);

    DynArrDelete(arr, -5, 1);
    PrintMgr("delete-clamped", arr);

    DynArrSetCapacity(arr, ti, 4);
    PrintMgr("setcap4", arr);

    DynArrSetLength(arr, ti, 6);
    PrintMgr("setlen6", arr);

    DynArrReserve(arr, ti, 20);
    PrintMgr("reserve20", arr);

    DynArrCompact(arr);
    PrintMgr("compact", arr);

    DynArrClear(arr);
    PrintMgr("clear-keep", arr);

    DynArrClear(arr, true);
    PrintRefState("clear-free", arr);
endfunc

function RunAssignClonePop(ti : ^SDqTypeInfo):
    var a : ODynArrMgr = null;
    var b : ODynArrMgr = null;
    var c : ODynArrMgr = null;
    var src : [3]int = [1, 2, 3];

    DynArrAssignData(a, ti, &src[0], 3);
    DynArrAssignOther(b, a);
    PrintRefState("assigned-a", a);
    PrintRefState("assigned-b", b);

    var tail : int = 4;
    DynArrAppend(b, ti, &tail, 1);
    PrintMgr("shared-a", a);

    DynArrClone(c, ti, a);
    ^int(DynArrGetElemPtr(c, 0))^ = 99;
    PrintMgr("clone-src", a);
    PrintMgr("clone-copy", c);

    var popped : int = 0;
    DynArrPop(c, &popped);
    printf("pop-last = %li\n", popped);
    DynArrPopFirst(c, &popped);
    printf("pop-first = %li\n", popped);
    PrintMgr("after-pop", c);

    DynArrAssignData(a, ti, null, 0);
    PrintRefState("assign-empty-a", a);
    PrintRefState("assign-empty-b", b);

    DynArrDecRef(b);
    DynArrDecRef(c);
endfunc

function RunSlicesOverlap(ti : ^SDqTypeInfo):
    var arr : ODynArrMgr = null;
    var src : [4]int = [1, 2, 3, 4];
    var desc : SArraySliceDesc = {};

    DynArrAssignData(arr, ti, &src[0], 4);
    DynArrGetSlice(arr, desc, -2, 3);
    PrintSlice("slice-clamped", desc);
    DynArrGetSlice(arr, desc, 3, 1);
    PrintSlice("slice-empty", desc);

    DynArrAppend(arr, ti, arr.dataptr, arr.length);
    PrintMgr("overlap-append", arr);

    DynArrAssignData(arr, ti, &src[0], 4);
    DynArrInsert(arr, ti, 2, ^byte(arr.dataptr)[1 * arr.elemsize], 2);
    PrintMgr("overlap-insert-cross", arr);

    DynArrDecRef(arr);
endfunc

function *Main() -> int:
    printf("DQ ODynArrMgr test\n"); //?ignore("DQ ODynArrMgr test")

    var ti : SDqTypeInfo = {};
    MakeIntTypeInfo(ti);

    RunCoreOps(&ti); //?check("initial", "len:0, cap:0, data: []")
                    //?check("append5", "len:5, cap:8, data: [10,20,30,40,50]")
                    //?check("insert-mid", "len:7, cap:8, data: [10,111,222,20,30,40,50]")
                    //?check("delete-clamped", "len:6, cap:8, data: [111,222,20,30,40,50]")
                    //?check("setcap4", "len:4, cap:4, data: [111,222,20,30]")
                    //?check("setlen6", "len:6, cap:8, data: [111,222,20,30,0,0]")
                    //?check("reserve20", "len:6, cap:32, data: [111,222,20,30,0,0]")
                    //?check("compact", "len:6, cap:6, data: [111,222,20,30,0,0]")
                    //?check("clear-keep", "len:0, cap:6, data: []")
                    //?check("clear-free", "null")

    RunAssignClonePop(&ti); //?check("assigned-a", "refcount:2, len:3, cap:3")
                            //?check("assigned-b", "refcount:2, len:3, cap:3")
                            //?check("shared-a", "len:4, cap:6, data: [1,2,3,4]")
                            //?check("clone-src", "len:4, cap:6, data: [1,2,3,4]")
                            //?check("clone-copy", "len:4, cap:4, data: [99,2,3,4]")
                            //?check("pop-last", 4)
                            //?check("pop-first", 99)
                            //?check("after-pop", "len:2, cap:4, data: [2,3]")
                            //?check("assign-empty-a", "null")
                            //?check("assign-empty-b", "refcount:1, len:4, cap:6")

    RunSlicesOverlap(&ti); //?check("slice-clamped", "len:3, data: [ 1, 2, 3]")
                           //?check("slice-empty", "len:0, data: []")
                           //?check("overlap-append", "len:8, cap:8, data: [1,2,3,4,1,2,3,4]")
                           //?check("overlap-insert-cross", "len:6, cap:8, data: [1,2,2,3,3,4]")

    return 0;
endfunc

// These expressions are specified as runtime bounds errors when executed.
// The test keeps them uncalled so the compiler must accept them as runtime checks.

use libc/stdio;

function StaticOutOfBoundsExpressions() -> int:
  var arr : [?]int = [10, 20, 30, 40, 50];
  var value : int = 0;
  value += arr[-1];
  value += arr[5];
  value += arr[$end];
  result = value;
endfunc

function DynamicOutOfBoundsExpressions() -> int:
  var arr : [*]int = [10, 20, 30];
  var value : int = 0;
  value += arr[-1];
  value += arr[3];
  value += arr[$end];
  result = value;
endfunc

function SliceOutOfBoundsExpressions() -> int:
  var base : [?]int = [10, 20, 30];
  var arr : []int = base[1:2];
  var value : int = 0;
  value += arr[-1];
  value += arr[1];
  value += arr[$end];
  result = value;
endfunc

function *Main() -> int:
  printf("array_index_runtime_semantics = compiled\n"); //?check("array_index_runtime_semantics", "compiled")
  return 0;
endfunc

// RTL string conversion and scalar slicing helpers for dq-str-v2 preparation.

use libc/stdio;
use rtl/strfunc;

function PrintBytes(label : ^char, text : strview):
    printf("%s = len:%li bytes:", label, text.length);
    var i : int = 0;
    while i < text.length:
        printf(" %li", int(uint32(Ord(text[i])) AND uint32(0xFF)));
        i += 1;
    endwhile
    printf("\n");
endfunc

function PrintWCharArray(label : ^char, arr : []wchar):
    printf("%s = len:%li data:", label, arr.length);
    var i : int = 0;
    while i < arr.length:
        printf(" %li", Ord(arr[i]));
        i += 1;
    endwhile
    printf("\n");
endfunc

function PrintChar16Array(label : ^char, arr : []char16):
    printf("%s = len:%li data:", label, arr.length);
    var i : int = 0;
    while i < arr.length:
        printf(" %li", Ord(arr[i]));
        i += 1;
    endwhile
    printf("\n");
endfunc

function Flag(v : bool) -> int:
    if v:
        result = 1;
    else:
        result = 0;
    endif
endfunc

function SampleUtf8() -> str:
    result = '';
    result.Append('A');          // U+0041
    result.Append(char(0xC3));   // U+00E9
    result.Append(char(0xA9));
    result.Append(char(0xE2));   // U+20AC
    result.Append(char(0x82));
    result.Append(char(0xAC));
    result.Append(char(0xF0));   // U+1F600
    result.Append(char(0x9F));
    result.Append(char(0x98));
    result.Append(char(0x80));
endfunc

function *Main() -> int:
    printf("string_strfunc_helpers = start\n"); //?check("string_strfunc_helpers", "start")

    var sample : str = SampleUtf8();
    PrintBytes("strf_sample_bytes", sample); //?check("strf_sample_bytes", "len:10 bytes: 65 195 169 226 130 172 240 159 152 128")
    printf("strf_wclen = %li\n", StrfWcLen(sample)); //?check("strf_wclen", 4)
    printf("strf_at = %li %li %li %li\n",
           Ord(StrfWCharAt(sample, 0)), Ord(StrfWCharAt(sample, 1)), Ord(StrfWCharAt(sample, 2)), Ord(StrfWCharAt(sample, 3)));
           //?check("strf_at", "65 233 8364 128512")

    var decoded : [*]wchar = StrfToWchars(sample);
    PrintWCharArray("strf_to_wchars", decoded[:]); //?check("strf_to_wchars", "len:4 data: 65 233 8364 128512")
    var sliced : [*]wchar = StrfWCharSlice(sample, 1, 3);
    PrintWCharArray("strf_wchar_slice", sliced[:]); //?check("strf_wchar_slice", "len:2 data: 233 8364")
    PrintBytes("strf_wcstr_slice", StrfWcStrSlice(sample, 1, 3)); //?check("strf_wcstr_slice", "len:5 bytes: 195 169 226 130 172")

    printf("str_syntax_wclen = %li\n", sample.wclen); //?check("str_syntax_wclen", 4)
    printf("str_syntax_wchar_at = %li %li %li %li\n",
           Ord(sample.wchar[0]), Ord(sample.wchar[1]), Ord(sample.wchar[2]), Ord(sample.wchar[$last]));
           //?check("str_syntax_wchar_at", "65 233 8364 128512")
    var syntax_slice : [*]wchar = sample.wchar[1:$end];
    PrintWCharArray("str_syntax_wchar_slice", syntax_slice[:]); //?check("str_syntax_wchar_slice", "len:3 data: 233 8364 128512")
    var syntax_to_wchars : [*]wchar = sample.ToWchars();
    PrintWCharArray("str_syntax_to_wchars", syntax_to_wchars[:]); //?check("str_syntax_to_wchars", "len:4 data: 65 233 8364 128512")

    var sample_view : strview = sample[:];
    printf("strview_syntax_wclen = %li\n", sample_view.wclen); //?check("strview_syntax_wclen", 4)
    printf("strview_syntax_wchar_at = %li\n", Ord(sample_view.wchar[2])); //?check("strview_syntax_wchar_at", 8364)
    var view_slice : [*]wchar = sample_view.wchar[:2];
    PrintWCharArray("strview_syntax_wchar_slice", view_slice[:]); //?check("strview_syntax_wchar_slice", "len:2 data: 65 233")

    var wchars : [*]wchar = [wchar(65), wchar(233), wchar(8364), wchar(128512)];
    PrintBytes("strf_from_wchars", StrfFromWchars(wchars[:])); //?check("strf_from_wchars", "len:10 bytes: 65 195 169 226 130 172 240 159 152 128")

    var utf16 : [*]char16 = StrfToUtf16(sample);
    PrintChar16Array("strf_to_utf16", utf16[:]); //?check("strf_to_utf16", "len:6 data: 65 233 8364 55357 56832 0")
    PrintBytes("strf_from_utf16", StrfFromUtf16(utf16[:])); //?check("strf_from_utf16", "len:10 bytes: 65 195 169 226 130 172 240 159 152 128")

    var with_zero : [*]char16 = [char16(65), char16(0), char16(66), char16(0)];
    PrintBytes("strf_utf16_internal_zero", StrfFromUtf16(with_zero[:])); //?check("strf_utf16_internal_zero", "len:3 bytes: 65 0 66")
    PrintBytes("strf_utf16_ptr_exact", StrfFromUtf16Ptr(&with_zero[0], 3)); //?check("strf_utf16_ptr_exact", "len:3 bytes: 65 0 66")

    var invalid : str = '';
    invalid.Append(char(0xC0));
    invalid.Append(char(0x80));
    printf("strf_is_utf8 = good:%li bad:%li\n", Flag(StrfIsUtf8(sample)), Flag(StrfIsUtf8(invalid))); //?check("strf_is_utf8", "good:1 bad:0")

    var bad16 : [*]char16 = [char16(0xD800), char16(65), char16(0)];
    PrintBytes("strf_utf16_fallback", StrfFromUtf16Fallback(bad16[:], wchar(63))); //?check("strf_utf16_fallback", "len:2 bytes: 63 65")

    printf("int_to_char = %li %li %li\n", Ord(IntToChar(65)), Ord(IntToChar(255)), Ord(IntToChar(-1, '?'))); //?check("int_to_char", "65 255 63")
    printf("int_to_wchar = %li %li\n", Ord(IntToWchar(0x41)), Ord(IntToWchar(0x110000, '?'))); //?check("int_to_wchar", "65 63")

    var caught_char : bool = false;
    try:
        var bad_char : char = IntToChar(-1);
    except Exception:
        caught_char = true;
    endtry

    var caught_wchar : bool = false;
    try:
        var bad_wchar : wchar = IntToWchar(0xD800);
    except Exception:
        caught_wchar = true;
    endtry
    printf("int_to_char_wchar_raise = %li %li\n", Flag(caught_char), Flag(caught_wchar)); //?check("int_to_char_wchar_raise", "1 1")

    return 0;
endfunc

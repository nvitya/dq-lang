
use print

const default_f1 : float64  = 2.200002
const default_f2 : float64  = 2.200001
const default_million_iter : int = 5

function StrToInt(sv : strview, defvalue : int64 = 0) -> int64:
    result = 0
    var sign : int = 1
    for i : int = 0 count sv.length:
        var c : char = sv[i]
        if c == '-':
            sign = -1
        elif c >= '0'  and  c <= '9':
            result = result * 10 + int64(c - '0')
        else:
            return defvalue
        endif
    endfor
endfunc

struct timespec:
    tv_sec  : int64
    tv_nsec : int64
endstruct

function clock_gettime(clk_id : int, res : ^timespec) [[external('clock_gettime')]];

const CLOCK_MONOTONIC : int = 1

function MilliTime() -> float64:
    var tv : timespec
    tv.tv_sec = 0
    clock_gettime(CLOCK_MONOTONIC, &tv)
    result = tv.tv_sec * 1000 + tv.tv_nsec / 1000000
endfunc

//---------------------------------------------------------------------------------------

function FpBench_f32(f1 : float32, f2 : float32, iterations : int) -> float32:
		result = 1.0
		for i : int = 0 count iterations:
			result *= f1
			result /= f2
		endfor
endfunc

function FpBench_f64(f1 : float64, f2 : float64, iterations : int) -> float64:
		result = 1.0
		for i : int = 0 count iterations:
			result *= f1
			result /= f2
		endfor
endfunc

function *Main() -> int:
    PrintLn('Floating Point Benchmark [DQ]')

		var f1 : float64 = default_f1
		var f2 : float64 = default_f2
    var million_iter : int = default_million_iter

    var ans : float64
		var tstart : float64
    var tend : float64

		if ParamCount() > 1:
			million_iter = StrToInt(ParamStr(1), million_iter)
    endif

		var iterations : int = million_iter * 1000000

		PrintLn("FP32 benchmark with F1={}, F2={}, million_iterations={}:", [f1, f2, million_iter])
		tstart = MilliTime()
		ans = FpBench_f32(f1, f2, iterations)
		tend = MilliTime()
		PrintLn("  ans = {}, time = {:.3f} ms", [ans, tend - tstart])
		PrintLn("  {} loop/msec", [floor(iterations/(tend - tstart))])

		PrintLn("FP64 benchmark with F1={}, F2={}, million_iterations={}:", [f1, f2, million_iter])
		tstart = MilliTime()
		ans = FpBench_f64(f1, f2, iterations)
		tend = MilliTime()
		PrintLn("  ans = {}, time = {:.3f} ms", [ans, tend - tstart])
		PrintLn("  {} loop/msec", [floor(iterations/(tend - tstart))])

    return 0
endfunc
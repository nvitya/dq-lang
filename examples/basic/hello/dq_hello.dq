// Standalone DQ hello world - no C testbed, linked directly to libc

[[external]] function printf(fmt : ^cchar, ...) -> int;

function main(argc : int, argv : ^^cchar) -> int:
  printf("Hello from DQ!\n");
  printf("DQ can call %s functions like %s directly.\n", "libc", "printf");
  printf("The answer is %ld.\n", 42);
  printf("argument count: %ld\n", argc);
  var i : int = 1;
  while i < argc:
    printf('  arg(%ld)="%s"\n', i, argv[i]^);
    i += 1;
  endwhile
  result = 0;
endfunc

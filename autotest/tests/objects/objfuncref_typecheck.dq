// object function reference type checking tests (ERROR test)

type FObjText = function(msg : cstring) of object;
type FObjInt = function(v : int) of object;
type FObjFloat = function(v : float) of object;
type FPlainText = function(msg : cstring);

function plain(msg : cstring):
endfunc

object OCallback:
    function *Create():
    endfunc

    function Print(msg : cstring):
    endfunc

    function Pick(msg : cstring) [[overload]]:
    endfunc

    function Pick(v : int) [[overload]]:
    endfunc
endobj

function *Main() -> int:
    var obj <- OCallback();
    var obj_text : FObjText = null;
    var obj_int : FObjInt = null;
    var obj_float : FObjFloat = null;
    var plain_text : FPlainText = plain;

    obj_text = plain;      //?error(FuncSigType)
    plain_text = obj.Print; //?error(FuncSigType)
    obj_int = obj.Print;   //?error(FuncSigType)
    obj_text = obj.Pick;
    obj_int = obj.Pick;
    obj_float = obj.Pick;  //?error(OverloadNoMatch)

    return 0;
endfunc

// DQ numeric for-loop auto-test

#ifdef ERRORTEST

function dq_for_missing_var() -> int:
  result = 0;
  for missing = 0 to 2:  //?error(VarUnknown)
  endfor
endfunc

function dq_for_type_mismatch() -> int:
  result = 0;
  var i : int16 = 0;
  for i : int = 0 to 2:  //?error(TypeMismatchAssign)
  endfor
endfunc

function dq_for_non_bool_while() -> int:
  result = 0;
  var i : int = 0;
  for i = 0 while i:  //?error(BoolExprExpected)
  endfor
endfunc

function dq_for_zero_step() -> int:
  result = 0;
  var i : int = 0;
  for i = 0 to 4 step 0:  //?error(ForStepPositive)
  endfor
endfunc

function dq_for_negative_range_step() -> int:
  result = 0;
  var i : int = 0;
  for i = 4 downto 0 step -1:  //?error(ForStepPositive)
  endfor
endfunc

#else

[[external]] function printf(fmt : ^cchar, ...) -> int;

function dq_for_to_sum() -> int:
  result = 0;
  var i : int = 0;
  for i = 0 to 5:
    result += i;
  endfor
endfunc

function dq_for_downto_sum() -> int:
  result = 0;
  var i : int = 0;
  for i = 5 downto 1:
    result += i;
  endfor
endfunc

function dq_for_to_step_sum() -> int:
  result = 0;
  var i : int = 0;
  for i = 0 to 10 step 2:
    result += i;
  endfor
endfunc

function dq_for_downto_step_sum() -> int:
  result = 0;
  var i : int = 0;
  for i = 10 downto 0 step 3:
    result += i;
  endfor
endfunc

function dq_for_count_sum() -> int:
  result = 0;
  var i : int = 0;
  for i = 0 count 5:
    result += i;
  endfor
endfunc

function dq_for_downcount_sum() -> int:
  result = 0;
  var i : int = 0;
  for i = 10 downcount 5:
    result += i;
  endfor
endfunc

function dq_for_count_step_sum() -> int:
  result = 0;
  var i : int = 0;
  for i = 0 count 5 step 2:
    result += i;
  endfor
endfunc

function dq_for_while_step_sum() -> int:
  result = 0;
  var i : int = 0;
  for i = 0 while i < 5 step 2:
    result += i;
  endfor
endfunc

function dq_for_while_negative_step_sum() -> int:
  result = 0;
  var i : int = 0;
  for i = 5 while i > 0 step -2:
    result += i;
  endfor
endfunc

function dq_for_continue_step() -> int:
  result = 0;
  var i : int = 0;
  for i = 0 count 5:
    if i == 2:
      continue;
    endif
    result += i;
  endfor
endfunc

function dq_for_break() -> int:
  result = 0;
  var i : int = 0;
  for i = 0 count 10:
    if i == 3:
      break;
    endif
    result += i;
  endfor
endfunc

function dq_for_local_decl() -> int:
  result = 0;
  for i : int = 1 to 3:
    result += i;
  endfor
endfunc

function dq_for_typed_reuse() -> int:
  var i : int = 100;
  for i : int = 0 count 3:
  endfor
  result = i;
endfunc

function dq_for_braces() -> int
{
  result = 0;
  var i : int = 0;
  for i = 0 to 2
  {
    result += i;
  }
}

function main() -> int:
  result = 0;
  printf("DQ for loop test\n");  //?ignore('DQ for loop test')

  printf("dq_for_to_sum() = %li\n", dq_for_to_sum());  //?check('dq_for_to_sum()', 15)
  printf("dq_for_downto_sum() = %li\n", dq_for_downto_sum());  //?check('dq_for_downto_sum()', 15)
  printf("dq_for_to_step_sum() = %li\n", dq_for_to_step_sum());  //?check('dq_for_to_step_sum()', 30)
  printf("dq_for_downto_step_sum() = %li\n", dq_for_downto_step_sum());  //?check('dq_for_downto_step_sum()', 22)
  printf("dq_for_count_sum() = %li\n", dq_for_count_sum());  //?check('dq_for_count_sum()', 10)
  printf("dq_for_downcount_sum() = %li\n", dq_for_downcount_sum());  //?check('dq_for_downcount_sum()', 40)
  printf("dq_for_count_step_sum() = %li\n", dq_for_count_step_sum());  //?check('dq_for_count_step_sum()', 20)
  printf("dq_for_while_step_sum() = %li\n", dq_for_while_step_sum());  //?check('dq_for_while_step_sum()', 6)
  printf("dq_for_while_negative_step_sum() = %li\n", dq_for_while_negative_step_sum());  //?check('dq_for_while_negative_step_sum()', 9)
  printf("dq_for_continue_step() = %li\n", dq_for_continue_step());  //?check('dq_for_continue_step()', 8)
  printf("dq_for_break() = %li\n", dq_for_break());  //?check('dq_for_break()', 3)
  printf("dq_for_local_decl() = %li\n", dq_for_local_decl());  //?check('dq_for_local_decl()', 6)
  printf("dq_for_typed_reuse() = %li\n", dq_for_typed_reuse());  //?check('dq_for_typed_reuse()', 3)
  printf("dq_for_braces() = %li\n", dq_for_braces());  //?check('dq_for_braces()', 3)
endfunc

#endif

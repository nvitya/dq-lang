// ODynStrMgr regression tests

use libc/stdio;
use rtl/strfunc;

function MakeText(desc : refout SDqTextInfo, data : ^char, alen : uint32):
    desc.dataptr = data;
    desc.charlen = alen;
    desc.info = (alen AND DQTI_MAXCHLEN_MASK) OR DQTIF_CHARLEN_VALID;
endfunc

function PrintText(label : ^char, s : ref ODynStrMgr):
    var view : SDqTextInfo = {};
    DynStrGetFullView(s, view);

    printf("%s = len:%li cap:%li text: \"", label, int(DynStrGetLength(s)), int(DynStrGetCapacity(s)));
    var i : int = 0;
    while i < view.charlen:
        printf("%c", Ord(view.dataptr[i]^));
        i += 1;
    endwhile
    printf("\"\n");
endfunc

function RunCoreOps():
    var s : ODynStrMgr = null;
    var src : [3]char = [char(97), char(98), char(99)];
    var desc : SDqTextInfo = {};
    MakeText(desc, &src[0], 3);
    DynStrAssignData(s, desc);
    PrintText("assign", s);

    var more : [2]char = [char(100), char(101)];
    MakeText(desc, &more[0], 2);
    DynStrAppend(s, desc, 2);
    PrintText("append", s);

    var ins : [2]char = [char(88), char(89)];
    MakeText(desc, &ins[0], 2);
    DynStrInsert(s, 2, desc, 2);
    PrintText("insert", s);

    DynStrDelete(s, -5, 1);
    PrintText("delete-clamped", s);

    DynStrSetLength(s, 4);
    PrintText("setlen4", s);

    DynStrCompact(s);
    PrintText("compact", s);

    DynStrClear(s, true);
    PrintText("clear-free", s);
endfunc

function RunOverlapClonePop():
    var s : ODynStrMgr = null;
    var src : [3]char = [char(97), char(98), char(99)];
    var desc : SDqTextInfo = {};
    MakeText(desc, &src[0], 3);
    DynStrAssignData(s, desc);

    DynStrGetView(s, desc, 1, 3);
    DynStrInsert(s, 2, desc, 2);
    PrintText("overlap-insert", s);

    var copy : ODynStrMgr = null;
    DynStrClone(s, copy);
    PrintText("clone", copy);

    var tail : ODynStrMgr = null;
    DynStrPop(s, 2, tail);
    PrintText("pop-tail", tail);
    PrintText("after-pop-tail", s);

    var head : ODynStrMgr = null;
    DynStrPopFirst(s, 1, head);
    PrintText("pop-head", head);
    PrintText("after-pop-head", s);

    DynStrDecRef(s);
    DynStrDecRef(copy);
    DynStrDecRef(tail);
    DynStrDecRef(head);
endfunc

function RunCopyOnWrite():
    var a : ODynStrMgr = null;
    var b : ODynStrMgr = null;
    var src : [3]char = [char(97), char(98), char(99)];
    var desc : SDqTextInfo = {};
    MakeText(desc, &src[0], 3);
    DynStrAssignData(a, desc);
    DynStrAssignOther(b, a);

    var suffix : [1]char = [char(120)];
    MakeText(desc, &suffix[0], 1);
    DynStrAppend(b, desc, 1);
    PrintText("cow-src", a);
    PrintText("cow-mutated", b);

    DynStrDecRef(a);
    DynStrDecRef(b);
endfunc

function *Main() -> int:
    printf("DQ ODynStrMgr test\n"); //?ignore("DQ ODynStrMgr test")

    RunCoreOps(); //?check("assign", 'len:3 cap:3 text: "abc"')
                  //?check("append", 'len:5 cap:6 text: "abcde"')
                  //?check("insert", 'len:7 cap:12 text: "abXYcde"')
                  //?check("delete-clamped", 'len:6 cap:12 text: "bXYcde"')
                  //?check("setlen4", 'len:4 cap:12 text: "bXYc"')
                  //?check("compact", 'len:4 cap:4 text: "bXYc"')
                  //?check("clear-free", 'len:0 cap:0 text: ""')

    RunOverlapClonePop(); //?check("overlap-insert", 'len:5 cap:6 text: "abbcc"')
                          //?check("clone", 'len:5 cap:5 text: "abbcc"')
                          //?check("pop-tail", 'len:2 cap:2 text: "cc"')
                          //?check("after-pop-tail", 'len:3 cap:6 text: "abb"')
                          //?check("pop-head", 'len:1 cap:1 text: "a"')
                          //?check("after-pop-head", 'len:2 cap:6 text: "bb"')

    RunCopyOnWrite(); //?check("cow-src", 'len:3 cap:3 text: "abc"')
                      //?check("cow-mutated", 'len:4 cap:6 text: "abcx"')

    return 0;
endfunc

// C string test

// new type: "cchar": 8-bit char, same as "char" in C
// fixed cstring(N): N usable cchars plus one hidden terminating zero byte

[[nowarn]] var dq_cstr  : cstring(256) = "DQ String Test\n";
[[nowarn]] var dq_cstr2 : cstring(40)  = 'Using signle quotes\n';

// These functions come from LIBC, so the program must be linked with the libc.
[[external]] function putchar(c : cchar) -> int;
[[external]] function puts(c : ^cchar) -> int;

function dq_writepc(s : ^cchar):
  var pc : ^cchar = s;
  while pc^ <> 0:
    putchar(pc^);
    pc += 1;
  endwhile
endfunc

function dq_writestr(s : cstring):
  var pc : ^cchar = &s[0];
  while pc^ <> 0:
    putchar(pc^);
    pc += 1;
  endwhile
endfunc

function cstr_add(dst : cstring, src : cstring):  // later this will be a DQ library function
  var ps     : ^cchar = &src[0];
  var psend  : ^cchar = ps + sizeof(src);
  var pd     : ^cchar = &dst[0];
  var pdend  : ^cchar = pd + sizeof(dst) - 1; // leave one char for the terminating
  pd += len(dst);
  var pdstart : ^cchar = pd;

  while pd < pdend  and ps < psend  and ps^ <> 0:
    pd^ = ps^;
    pd += 1;
    ps += 1;
  endwhile

  if pd <> pdstart:
    pd^ = 0; // terminate
  endif
endfunc

function dq_str_append(a : cstring, b : cstring):

  // len(cstring): length of the actual contents
  // sizeof(cstring): storage size of the argument variable

  if len(a) + len(b) > sizeof(a) - 1:  // append to the a only when the whole will fit.
    return;
  endif
  cstr_add(a, b);
endfunc
function *Main() -> int:
  dq_writepc('dq_cstr = ');
  dq_writestr(dq_cstr);  //?check('dq_cstr', 'DQ String Test')

  [[nowarn]] var s : cstring(128) = "";

  var warn_s1 : cstring(4); //?warning(CStrStorageSize)
  [[nowarn]] var warn_s2 : cstring(4);

  [[nowarn]] var hello : cstring(5) = "Hello";
  [[nowarn]] var world : cstring(8) = " World!\n";
  cstr_add(s, hello);
  cstr_add(s, world);

  dq_writepc('s = ');
  dq_writestr(s);
                           //?check('s', 'Hello World!')

  // string length checking test
  [[nowarn]] var s2 : cstring(8);
  s2 = "abc";
  var def : cstring(3) = "def";
  [[nowarn]] var too_long : cstring(12) = "ghijklmnopqr";
  dq_str_append(s2, def);
  dq_str_append(s2, too_long);

  dq_writepc('s2 = "');
  dq_writestr(s2);
  dq_writepc('"\n');     //?check(s2, '"abcdef"')

  [[nowarn]] var s3 : cstring(4) = "";
  [[nowarn]] var s4 : cstring(8) = "abcdef";
  s3 = s4;
  dq_writepc('s3 = "');
  dq_writestr(s3);
  dq_writepc('"\n');     //?check(s3, '"abcd"')

  [[nowarn]] var s5 : cstring(8) = "";
  s5 = s3;
  dq_writepc('s5 = "');
  dq_writestr(s5);
  dq_writepc('"\n');     //?check(s5, '"abcd"')

  var pc : ^cchar = "asdf";
  [[nowarn]] var cs : cstring(32);
  cs = pc;
  dq_writepc('cs = "');
  dq_writestr(cs);
  dq_writepc('"\n');     //?check(cs, '"asdf"')

  return 0;
endfunc

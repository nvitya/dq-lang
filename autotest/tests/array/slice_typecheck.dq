// Slice compile-time rejection cases from the array specification.

function SliceStructuralMethodsAreInvalid():
  var source : [?]int = [1, 2, 3];
  var slice : []int = source[:];
  slice.Append(4); //?error(MemberUnknown)
  slice.Prepend(0); //?error(MemberUnknown)
  slice.Insert(1, 9); //?error(MemberUnknown)
  slice.Delete(1); //?error(MemberUnknown)
  slice.SetLength(4); //?error(MemberUnknown)
  slice.SetCapacity(4); //?error(MemberUnknown)
  slice.Reserve(10); //?error(MemberUnknown)
  slice.Compact(); //?error(MemberUnknown)
  slice.Clear(); //?error(MemberUnknown)
  slice.Clone(); //?error(MemberUnknown)
  slice.Pop(); //?error(MemberUnknown)
  slice.PopFirst(); //?error(MemberUnknown)
endfunc

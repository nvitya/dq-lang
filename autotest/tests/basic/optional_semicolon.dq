[[external]] function printf(fmt : ^char, ...) -> int;

function test_optional_semicolon():
    var a : int = 10
    var b : int = 20
    var c : int = a + b

    if c == 30:
        printf("Optional semicolon works!\n")  //?ignore('Optional semicolon works!')
    endif
endfunc

function *Main() -> int:
    test_optional_semicolon()
    return 0
endfunc


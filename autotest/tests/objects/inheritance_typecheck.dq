// object inheritance type checking tests (ERROR test)

object OBase:
private
  secret : int;
  function SecretFunc():
  endfunc
protected
  hidden : int;
public
  function *Create():
  endfunc

  function Value() -> int [[virtual]]:
    return hidden;
  endfunc

  function Done() [[virtual, final]]:
  endfunc
endobj

object OChild(OBase):
public
  function *Create():
    hidden = 1;
  endfunc //?error(ObjSpecFuncInvalid)

  function Value() -> int: //?error(ObjFuncOverride)
    return hidden;
  endfunc

  function Missing() [[override]]: //?error(ObjFuncOverride)
  endfunc

  function Done() [[override]]: //?error(ObjFuncOverride)
  endfunc
endobj

object OAccessChild(OBase):
public
  function *Create():
    inherited Create();
  endfunc

  function ReadSecret() -> int:
    result = 0;
    result = secret; //?error(MemberUnknown)
  endfunc

  function CallSecret():
    inherited SecretFunc(); //?error(OverloadNoMatch)
  endfunc
endobj

object OAbstract:
public
  function Read() -> int [[virtual, abstract]];
endobj

object OVirtualDtorCall:
public
  function Ping(a : int) [[virtual, overload]]:
  endfunc

  function Ping(a : float) [[virtual, overload]]:
  endfunc

  function *Destroy():
    Ping(1); //?error(VirtFuncCallInvalid)
  endfunc
endobj

function MutObjectRef(o : ref OBase):
endfunc

function *Main() -> int:
  result = 0;
  var b <- OBase();
  var c <- OChild();
  result = b.hidden;  //?error(MemberUnknown)
  MutObjectRef(b); //?error(FuncArgRefBind)
  var a <- OAbstract; //?error(NotSupported)
endfunc

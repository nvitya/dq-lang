{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "dq: build configured target",
      "type": "shell",
      "command": "build/dq-comp",
      "args": [
        "-g",
        "-O0",
        "${config:dq.debugTarget}.dq",
        "-o",
        "${config:dq.debugTarget}"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "dq: build active file",
      "type": "shell",
      "command": "build/dq-comp",
      "args": [
        "-g",
        "-O0",
        "${file}",
        "-o",
        "${fileDirname}/${fileBasenameNoExtension}"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": []
    }
  ]
}

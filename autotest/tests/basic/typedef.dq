// type definition example

type TFloat = float64;

var f1 : TFloat = 1;
var f2 : TFloat = 2;
var f64 : float = 5.5;

[[external]] function printf(fmt : ^cchar, ...) -> int;

[[cexport]]
function main() -> int:
  printf('DQ Typedef test\n');    //?check('DQ Typedef test')
  var f : TFloat = f1;
  printf('float = %.3f\n', 0.1);  //?check(float, 0.100)
  printf('f64 = %.3f\n', f64);    //?check(f64,   5.500)
  printf('f = %.3f\n', f);        //?check(f,     1.000)
  return 0;
endfunc
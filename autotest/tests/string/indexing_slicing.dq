// Spec-level string indexing, context values, and clamped slicing behavior.

use libc/stdio;

[[external]] function putchar(c : char) -> int;

function PrintEscapedChar(ch : char):
    if ch == char(9):
        printf("\\t");
        return;
    endif
    if ch == char(10):
        printf("\\n");
        return;
    endif
    if ch == char(13):
        printf("\\r");
        return;
    endif
    if ch == char(34):
        putchar(char(92));
        putchar(char(34));
        return;
    endif
    if ch == char(92):
        putchar(char(92));
        putchar(char(92));
        return;
    endif
    putchar(char(ch));
endfunc

function PrintText(label : ^char, text : strview):
    printf("%s = [%li] \"", label, text.length);
    var i : int = 0;
    while i < text.length:
        PrintEscapedChar(text[i]);
        i += 1;
    endwhile
    printf("\"\n");
endfunc

function *Main() -> int:
    printf("string_indexing_slicing = start\n"); //?check("string_indexing_slicing", "start")

    var s : str = "abcdef";

    printf("string_index_values = first:%li mid:%li last:%li last_ctx:%li end:%li\n",
           s[0], s[2], s[5], s[$last], s.length); //?check("string_index_values", "first:97 mid:99 last:102 last_ctx:102 end:6")

    s[0] = 'A';
    s[5] = 'F';
    PrintText("string_index_assign", s); //?check("string_index_assign", '[6] "AbcdeF"')

    s = "abcdef";
    var copy_mid : str = s[1:4];
    var view_mid : strview = s[1:4];
    PrintText("slice_copy_mid", copy_mid); //?check("slice_copy_mid", '[3] "bcd"')
    PrintText("slice_view_mid", view_mid); //?check("slice_view_mid", '[3] "bcd"')

    PrintText("slice_whole", s[:]); //?check("slice_whole", '[6] "abcdef"')
    PrintText("slice_from_two", s[2:]); //?check("slice_from_two", '[4] "cdef"')
    PrintText("slice_to_three", s[:3]); //?check("slice_to_three", '[3] "abc"')
    PrintText("slice_from_two_inclusive_open", s[2::]); //?check("slice_from_two_inclusive_open", '[4] "cdef"')
    PrintText("slice_inclusive_mid", s[1::3]); //?check("slice_inclusive_mid", '[3] "bcd"')

    PrintText("slice_empty_equal_bounds", s[3:3]); //?check("slice_empty_equal_bounds", '[0] ""')
    PrintText("slice_empty_reversed", s[4:2]); //?check("slice_empty_reversed", '[0] ""')
    PrintText("slice_clamp_negative_start", s[-5:]); //?check("slice_clamp_negative_start", '[6] "abcdef"')
    PrintText("slice_clamp_large_end", s[:100]); //?check("slice_clamp_large_end", '[6] "abcdef"')
    PrintText("slice_clamp_large_start", s[100:]); //?check("slice_clamp_large_start", '[0] ""')
    PrintText("slice_clamp_then_empty", s[4:-2]); //?check("slice_clamp_then_empty", '[0] ""')

    PrintText("slice_last_only", s[$last:]); //?check("slice_last_only", '[1] "f"')
    PrintText("slice_end_empty", s[$end:]); //?check("slice_end_empty", '[0] ""')
    PrintText("slice_except_last", s[:$end - 1]); //?check("slice_except_last", '[5] "abcde"')
    PrintText("slice_last_two_inclusive", s[$end - 2::$end - 1]); //?check("slice_last_two_inclusive", '[2] "ef"')

    var v : strview = "abcdef";
    var vv : strview = v[1:4];
    PrintText("strview_slice", vv); //?check("strview_slice", '[3] "bcd"')

    return 0;
endfunc

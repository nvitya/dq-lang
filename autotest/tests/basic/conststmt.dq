// local const statement parsing and codegen tests

const rootval : int = 22;

function dq_local_const_basic() -> int:
    const base : int = 3;
    result = base + 4;
endfunc

function dq_local_const_shadow_root() -> int:
    const rootval : int = 11;
    result = rootval;
endfunc

function dq_local_const_in_if(a : int) -> int:
    if a > 0:
        const inc : int = 5;
        result = inc;
    else:
        result = rootval;
    endif
endfunc

function dq_local_const_nonconst_expr(a : int) -> int:
    const bad : int = a + 1;  //?error(ConstExprInvalid), error(ConstExprNonConstVs)
    result = 0;
endfunc

implementation

use print

object ONode [[forward]]

object ONode:
  left  : ONode
  right : ONode

  function *Create(aleft : ONode = null, aright : ONode = null)
  function *Destroy()
  function NodeCount() -> int
endobj

function ONode.*Create(aleft : ONode = null, aright : ONode = null):
  left  = aleft
  right = aright
endfunc

function ONode.*Destroy():
  if left <> null:
    delete left
  endif
  if right <> null:
    delete right
  endif
endfunc

function ONode.NodeCount() -> int:
  result = 1
  if left <> null:
    result += left.NodeCount()
  endif
  if right <> null:
    result += right.NodeCount()
  endif
endfunc

function BuildTree(depth : int) -> ONode
  if depth == 0:
    return new ONode()
  endif
  return new ONode( BuildTree(depth - 1), BuildTree(depth - 1) )
endfunc

function CountDepth(depth : int) -> int:
  var lnode : ONode = build_tree(depth)
  result = lnode.NodeCount()
  delete lnode  
endfunc

function StrechToDepth(depth : int):
  PrintLn('stretch tree of depth {}\t check: {}', [depth, count(depth)])
endfunc


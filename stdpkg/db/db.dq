
enum NSqlFieldType : byte = (
  ftUnknown = 0,
  ftInt,
  ftFloat,
  ftBool,
  ftText,
  ftBlob,
  ftDateTime
)

struct SFieldInfo:  // 72 bytes
  name  : cstring(67)
  index : byte
  ftype : NSqlFieldType
  _pad  : [2]byte
endstruct

object ODbConnection  [[forward]]
object ODbDataSource  [[forward]]

object ODbRows:
protected
  m_fieldcount : int
  m_rowcount   : int
  m_fieldinfo  : [*]SFieldInfo

  m_data       : [*]anyvalue  // length = fieldcount * rowcount

  m_currow     : int // can be out of the valid range

  //m_datasource : ODbDataSource  // might be null for standalone / memory datasets

    function CellIndex(arow : int, afield : int) -> int

public
    function *Create()
    function *Destroy()

    function Clear()      // delete all rows, all fields
    function ClearRows()  //

    function RowCount() -> int
    function FieldCount() -> int

    function AddField(aname : str, atype : NSqlFieldType) -> int
    function FieldName(aindex : int) -> str
    function FieldIndex(aname : str) -> int
    function HasField(aname : str) -> bool

    function AddRow() -> int
    function DeleteRow(arow : int)

    // cursor navigation
    function First()
    function Last()
    function Next()
    function Prev()
    function SelectRow(arow : int) -> bool
    function RowIndex() -> int
    function Eof() -> bool
    function Bof() -> bool

    // current row access
    function IsNull(aname : str) -> bool
    function GetValue(aname : str) -> anyvalue
    function SetValue(aname : str, avalue : anyvalue)

    function GetInt(aname : str, defvalue : int) -> int
    function GetFloat(aname : str, defvalue : float) -> float
    function GetBool(aname : str, defvalue : bool) -> bool
    function GetStr(aname : str, defvalue : str) -> str

    function SetInt(aname : str, avalue : int)
    function SetFloat(aname : str, avalue : float)
    function SetBool(aname : str, avalue : bool)
    function SetStr(aname : str, avalue : str)
    function SetNull(aname : str)

    // direct row access, secondary API
    //function GetValueRow(arow : int, aname : str) -> anyvalue
    //function SetValueRow(arow : int, aname : str, avalue : anyvalue)
endobj


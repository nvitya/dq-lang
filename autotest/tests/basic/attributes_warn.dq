struct SAttr:
    [[volatile]] a : int;
    b : int [[volatile]];
endstruct

function printf(fmt : ^char, ...) -> int [[external('printf')]];
function puts(s : ^char) -> int [[external]];

var gv : int [[virtual]];                    //?warning(AttrIgnored)
const gc : int = 123 [[volatile]];          //?warning(AttrIgnored)
[[volatile]] function onlyext() -> int [[external]];  //?warning(AttrIgnored)
function *Main() -> int:
    printf("attr test %d\n", gc);
    puts("done");
    return 0;
endfunc

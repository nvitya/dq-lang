{
  "name": "dq-syntax",
  "displayName": "DQ Language Support",
  "description": "Minimal editor, build, and debug configuration support for DQ files.",
  "version": "0.0.1",
  "publisher": "local",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git@github.com:nvitya/dq-comp.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "files": [
    "language-configuration.json",
    "package.json",
    "README.md",
    "LICENSE.txt",
    "examples/**",
    "snippets/**",
    "syntaxes/**"
  ],
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "dq",
    "syntax",
    "highlighting"
  ],
  "contributes": {
    "languages": [
      {
        "id": "dq",
        "aliases": [
          "DQ",
          "dq"
        ],
        "extensions": [
          ".dq"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "dq",
        "scopeName": "source.dq",
        "path": "./syntaxes/dq.tmLanguage.json"
      }
    ],
    "problemMatchers": [
      {
        "name": "dq",
        "owner": "dq",
        "fileLocation": [
          "relative",
          "${workspaceFolder}"
        ],
        "pattern": {
          "regexp": "^(.*)\\((\\d+),(\\d+)\\)\\s+(error|warning|ERROR|WARNING)\\(([^)]+)\\):\\s+(.*)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "code": 5,
          "message": 6
        }
      }
    ],
    "snippets": [
      {
        "language": "dq",
        "path": "./snippets/dq.json"
      }
    ]
  }
}

use print
use strparse
use file

function ParseText(atxt : strview):
  PrintLn('--------------------------------')
  var sp <- OStrParse(atxt)
  sp.SkipSpaces()
  if not sp.CheckSymbol('{'):
    raise Exception('object start not found.')
  endif
  sp.SkipSpaces()
  if not sp.CheckSymbol('"strnode"'):
    raise Exception('strnode not found.')
  endif
  sp.SkipSpaces()
  if not sp.CheckSymbol(';'):
    raise Exception('":" expected')
  endif

  PrintLn('parsing finished.')
endfunc

function *Main() -> int:
  PrintLn('Testing OStrParse')

  var fdata : str = FileReadText('test.json')

  PrintLn('Test file data:\n{}', [fdata])
  ParseText(fdata)

  return 0
endfunc
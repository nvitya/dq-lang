
enum NDbFieldType : byte = (
    ftUnknown = 0,
    ftInt,
    ftFloat,
    ftBool,
    ftText,
    ftBlob,
    ftDateTime
)

struct SFieldInfo:  // 72 bytes
    name  : cstring(67)
    index : byte
    ftype : NDbFieldType
    _pad  : [2]byte
endstruct

object ODbConnection  [[forward]]
object ODbDataSource  [[forward]]

object EDbField(Exception):
endobj

object EDbRow(Exception):
endobj

object EDbFieldType(Exception):
endobj

object EDbFieldIndex(Exception):
endobj

object ODbRows:
protected
    m_fieldcount : int
    m_rowcount   : int
    m_fieldinfo  : [*]SFieldInfo

    m_data       : [*]anyvalue  // length = fieldcount * rowcount

    m_currow     : int   // can be out of the valid range
    m_onrow      : bool  // is the current row valid ?

    //m_datasource : ODbDataSource  // might be null for standalone / memory datasets

    function CellIndex(arow : int, afield : int) -> int  [[inline]]
    function GetCurRowDataIndex(aname : strview, rft : refout NDbFieldType) -> int

public
    function *Create()
    function *Destroy()

    function Clear()      // delete all rows, all fields
    function ClearRows()

    function RowCount() -> int
    function FieldCount() -> int

    function AddField(aname : strview, atype : NDbFieldType) -> int
    function FieldName(aindex : int) -> str
    function FieldType(aindex : int) -> NDbFieldType
    function FieldIndex(aname : strview) -> int
    function HasField(aname : strview) -> bool

    function AddRow() -> int
    function DeleteRow(arow : int)

    // cursor navigation
    function First()
    function Last()
    function Next()
    function Prev()
    function SelectRow(arow : int) -> bool
    function RowIndex() -> int

    function OnRow() -> bool

    // current row access
    function IsNull(aname : strview) -> bool
    function GetValue(aname : strview) -> anyvalue
    function SetValue(aname : strview, avalue : anyvalue)

    function GetInt(aname : strview, defvalue : int) -> int
    function GetFloat(aname : strview, defvalue : float) -> float
    function GetBool(aname : strview, defvalue : bool) -> bool
    function GetStr(aname : strview, defvalue : strview) -> str

    function SetInt(aname : strview, avalue : int)
    function SetFloat(aname : strview, avalue : float)
    function SetBool(aname : strview, avalue : bool)
    function SetStr(aname : strview, avalue : strview)
    function SetNull(aname : strview)

    // direct row access, secondary API
    //function GetValueRow(arow : int, aname : strview) -> anyvalue
    //function SetValueRow(arow : int, aname : strview, avalue : anyvalue)

    property onrow : bool  read m_onrow

endobj

